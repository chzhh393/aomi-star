.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a1a 0%, #1a1a1a 36%, #f5f5f5 36%, #ffffff 100%);
  padding: 28rpx 24rpx 120rpx;
}

.hero-panel {
  padding: 30rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #F8D55D 0%, #FADF7F 100%);
  box-shadow: 0 20rpx 40rpx rgba(248, 213, 93, 0.3);
}

.hero-topline {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.hero-badge,
.hero-date {
  font-size: 20rpx;
  color: rgba(30, 20, 18, 0.72);
  letter-spacing: 2rpx;
}

.hero-title {
  font-size: 46rpx;
  line-height: 1.18;
  font-weight: 700;
  color: #221714;
}

.hero-subtitle {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(34, 23, 20, 0.76);
}

.hero-user {
  margin-top: 24rpx;
  background: rgba(255, 255, 255, 0.85);
  border-radius: 22rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.hero-user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #F8D55D 0%, #FADF7F 100%);
  color: #1a1a1a;
  font-size: 36rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-user-content {
  flex: 1;
}

.hero-user-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.hero-user-role {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(26, 26, 26, 0.68);
}

.debug-panel {
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.85);
}

.debug-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.debug-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: rgba(26, 26, 26, 0.76);
}

.debug-button {
  margin-top: 16rpx;
  border: none;
  border-radius: 999rpx;
  background: #1a1a1a;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
}

.debug-button::after {
  border: none;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin: 24rpx 0;
}

.summary-card {
  min-height: 160rpx;
  border-radius: 28rpx;
  padding: 24rpx;
  box-sizing: border-box;
  background: #ffffff;
  border: 2rpx solid #e5e5e5;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.tone-dark {
  background: #1a1a1a;
  color: #ffffff;
  border: none;
}

.tone-gold {
  background: linear-gradient(135deg, #F8D55D 0%, #FADF7F 100%);
  color: #1a1a1a;
  border: none;
  box-shadow: 0 12rpx 24rpx rgba(248, 213, 93, 0.3);
}

.tone-white {
  background: #ffffff;
  color: #1b1c22;
}

.tone-green {
  background: #dff3dd;
  color: #2f7a2e;
  border-color: #dff3dd;
}

.tone-sand {
  background: #f9f9f9;
  color: #1b1c22;
}

.tone-plum {
  background: rgba(91, 138, 255, 0.14);
  color: #335ac2;
  border-color: rgba(91, 138, 255, 0.14);
}

.summary-value-row {
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
}

.summary-value {
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1;
}

.summary-unit {
  font-size: 24rpx;
  line-height: 1.2;
  margin-bottom: 4rpx;
}

.summary-label {
  margin-top: 14rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.summary-note {
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.5;
  opacity: 0.72;
}

.section {
  margin: 0 0 24rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 18rpx;
}

.section-en {
  font-size: 20rpx;
  color: #7d736a;
  letter-spacing: 2rpx;
}

.section-title {
  font-size: 30rpx;
  color: #1b1c22;
  font-weight: 700;
}

.metric-list,
.flow-list,
.alert-list,
.action-list,
.module-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.metric-item,
.flow-item,
.alert-item,
.action-item {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 24rpx;
  border: 2rpx solid #e5e5e5;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.metric-main,
.alert-title-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: baseline;
}

.metric-label,
.flow-name,
.alert-title,
.action-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #1b1c22;
}

.metric-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #F8D55D;
}

.metric-detail,
.flow-desc,
.alert-desc,
.action-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #5d5751;
}

.module-card {
  border-radius: 28rpx;
  padding: 24rpx;
  background: #ffffff;
  border: 2rpx solid #e5e5e5;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.module-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.module-tag {
  display: inline-flex;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(248, 213, 93, 0.2);
  color: #996B00;
  font-size: 20rpx;
  font-weight: 700;
}

.module-progress {
  font-size: 24rpx;
  font-weight: 700;
  color: #F8D55D;
}

.module-title {
  margin-top: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #1b1c22;
}

.module-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #5d5751;
}

.module-progress-bar {
  width: 100%;
  height: 10rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: #f0f0f0;
  margin-top: 20rpx;
}

.module-progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #F8D55D;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.chip {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  background: #f9f9f9;
  color: #5d5751;
  border: 2rpx solid #e5e5e5;
}

.module-metrics {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.module-metric {
  background: #f9f9f9;
  border-radius: 18rpx;
  padding: 16rpx;
  border: 2rpx solid #e5e5e5;
}

.module-metric-label {
  display: block;
  font-size: 20rpx;
  color: #7d736a;
}

.module-metric-value {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #1b1c22;
}

.flow-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.flow-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-top: 12rpx;
  flex-shrink: 0;
  background: #e5e5e5;
}

.status-done .flow-dot {
  background: #2f7a2e;
}

.status-current .flow-dot {
  background: #F8D55D;
  box-shadow: 0 0 0 8rpx rgba(248, 213, 93, 0.2);
}

.status-upcoming .flow-dot {
  background: #e5e5e5;
}

.alert-item.level-high {
  border-left: 8rpx solid #b73724;
}

.alert-item.level-medium {
  border-left: 8rpx solid #F8D55D;
}

.alert-owner {
  font-size: 20rpx;
  color: #7d736a;
}

.action-item {
  display: flex;
  gap: 18rpx;
  align-items: stretch;
}

.action-accent {
  width: 10rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
  background: #F8D55D;
}

.action-content,
.flow-content {
  flex: 1;
}

.action-item:active,
.module-card:active {
  transform: scale(0.98);
}
