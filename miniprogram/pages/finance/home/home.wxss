.container {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(240, 181, 72, 0.18), transparent 28%),
    linear-gradient(180deg, #0E1513 0%, #162521 18%, #F3EEE2 18%, #F3EEE2 100%);
  padding: 0 0 120rpx;
}

.hero-panel {
  padding: 40rpx 28rpx 44rpx;
}

.hero-topline {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.hero-badge,
.hero-date {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.72);
  letter-spacing: 2rpx;
}

.hero-title {
  font-size: 54rpx;
  line-height: 1.1;
  font-weight: 900;
  color: #FFFFFF;
}

.hero-subtitle {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.78);
}

.hero-user {
  margin-top: 28rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 28rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  backdrop-filter: blur(12rpx);
}

.hero-user-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  background: #E0A84D;
  color: #142019;
  font-size: 42rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-user-content {
  flex: 1;
}

.hero-user-name {
  font-size: 30rpx;
  font-weight: 900;
  color: #FFFFFF;
}

.hero-user-role {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.68);
}

.debug-panel {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(224, 168, 77, 0.14);
  border: 2rpx solid rgba(224, 168, 77, 0.2);
}

.debug-title {
  font-size: 24rpx;
  font-weight: 800;
  color: #F3D37A;
}

.debug-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.78);
}

.debug-button {
  margin-top: 18rpx;
  border: none;
  border-radius: 999rpx;
  background: #E0A84D;
  color: #142019;
  font-size: 24rpx;
  font-weight: 800;
}

.debug-button::after {
  border: none;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin: -12rpx 24rpx 24rpx;
}

.summary-card {
  min-height: 172rpx;
  border-radius: 28rpx;
  padding: 26rpx 24rpx;
  box-sizing: border-box;
}

.tone-dark {
  background: #13211D;
  color: #FFFFFF;
}

.tone-gold {
  background: linear-gradient(135deg, #F3D37A 0%, #E0A84D 100%);
  color: #1B1408;
}

.tone-white {
  background: #FFFFFF;
  color: #1A1A1A;
  box-shadow: 0 12rpx 30rpx rgba(17, 24, 39, 0.08);
}

.tone-green {
  background: linear-gradient(135deg, #1C8B68 0%, #2FB181 100%);
  color: #FFFFFF;
}

.tone-sand {
  background: #E9DCC3;
  color: #1E1A13;
}

.tone-plum {
  background: #35264F;
  color: #FFFFFF;
}

.summary-value-row {
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
}

.summary-value {
  font-size: 46rpx;
  font-weight: 900;
  line-height: 1;
}

.summary-unit {
  font-size: 24rpx;
  line-height: 1.2;
  margin-bottom: 4rpx;
}

.summary-label {
  margin-top: 16rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.summary-note {
  margin-top: 10rpx;
  font-size: 20rpx;
  line-height: 1.5;
  opacity: 0.72;
}

.section {
  margin: 0 24rpx 24rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 18rpx;
}

.section-en {
  font-size: 20rpx;
  color: #6B7280;
  letter-spacing: 2rpx;
}

.section-title {
  font-size: 32rpx;
  color: #142019;
  font-weight: 900;
}

.metric-list,
.flow-list,
.alert-list,
.action-list,
.module-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.metric-item,
.flow-item,
.alert-item,
.action-item {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.06);
}

.metric-main,
.alert-title-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: baseline;
}

.metric-label,
.flow-name,
.alert-title,
.action-label {
  font-size: 28rpx;
  font-weight: 800;
  color: #142019;
}

.metric-value {
  font-size: 28rpx;
  font-weight: 900;
  color: #A16207;
}

.metric-detail,
.flow-desc,
.alert-desc,
.action-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #59656A;
}

.module-card {
  border-radius: 28rpx;
  padding: 28rpx;
}

.module-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.module-tag {
  display: inline-flex;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 20rpx;
  font-weight: 800;
}

.module-progress {
  font-size: 24rpx;
  font-weight: 900;
}

.module-title {
  margin-top: 18rpx;
  font-size: 34rpx;
  font-weight: 900;
}

.module-desc {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.7;
  opacity: 0.86;
}

.module-progress-bar {
  width: 100%;
  height: 10rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.18);
  margin-top: 22rpx;
}

.module-progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: currentColor;
  opacity: 0.85;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.chip {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  background: rgba(255, 255, 255, 0.15);
}

.module-metrics {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.module-metric {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 18rpx;
  padding: 18rpx;
}

.module-metric-label {
  display: block;
  font-size: 20rpx;
  opacity: 0.76;
}

.module-metric-value {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.flow-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.flow-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-top: 12rpx;
  flex-shrink: 0;
  background: #CBD5E1;
}

.status-done .flow-dot {
  background: #0F766E;
}

.status-current .flow-dot {
  background: #D97706;
  box-shadow: 0 0 0 8rpx rgba(217, 119, 6, 0.14);
}

.status-upcoming .flow-dot {
  background: #94A3B8;
}

.alert-item.level-high {
  border-left: 8rpx solid #C2410C;
}

.alert-item.level-medium {
  border-left: 8rpx solid #D97706;
}

.alert-owner {
  font-size: 20rpx;
  color: #6B7280;
}

.action-item {
  display: flex;
  gap: 18rpx;
  align-items: stretch;
}

.action-accent {
  width: 10rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
}

.action-content,
.flow-content {
  flex: 1;
}

.action-item:active,
.module-card:active {
  transform: scale(0.98);
}
