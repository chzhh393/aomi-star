.page {
  min-height: 100vh;
  background: #f5efe6;
  padding: 32rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.hero {
  background: linear-gradient(135deg, #132a22, #305347);
  border-radius: 28rpx;
  padding: 32rpx;
  color: #f8f2e7;
  box-shadow: 0 18rpx 48rpx rgba(19, 42, 34, 0.16);
}

.hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
}

.hero-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(248, 242, 231, 0.82);
}

.stats-grid {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.stat-card {
  background: #fffaf2;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(33, 24, 14, 0.06);
}

.stat-card.is-pending {
  background: #16251d;
  color: #f8f2e7;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
}

.stat-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(47, 38, 28, 0.72);
}

.stat-card.is-pending .stat-label {
  color: rgba(248, 242, 231, 0.8);
}

.filter-row {
  margin-top: 24rpx;
  white-space: nowrap;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 26rpx;
  margin-right: 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 250, 242, 0.9);
  color: #5f513f;
  font-size: 24rpx;
}

.filter-chip.is-active {
  background: #16251d;
  color: #f8f2e7;
}

.empty-state {
  margin-top: 32rpx;
  background: #fffaf2;
  border-radius: 28rpx;
  padding: 56rpx 32rpx;
  text-align: center;
  box-shadow: 0 12rpx 32rpx rgba(33, 24, 14, 0.06);
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #2f261c;
}

.empty-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #8b7b68;
}

.list {
  margin-top: 24rpx;
}

.candidate-card {
  background: #fffaf2;
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 12rpx 32rpx rgba(33, 24, 14, 0.06);
}

.card-head,
.card-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.candidate-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #20180f;
}

.candidate-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8b7b68;
}

.status-group {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.status-badge {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.status-badge.finance-pending {
  background: rgba(180, 83, 9, 0.14);
  color: #b45309;
}

.status-badge.finance-approved {
  background: rgba(5, 150, 105, 0.14);
  color: #047857;
}

.status-badge.finance-rejected {
  background: rgba(185, 28, 28, 0.14);
  color: #b91c1c;
}

.status-badge.finance-none {
  background: rgba(107, 114, 128, 0.12);
  color: #6b7280;
}

.status-hint {
  font-size: 20rpx;
  color: #8b7b68;
}

.detail-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 24rpx;
}

.detail-item {
  background: #f7f1e7;
  border-radius: 20rpx;
  padding: 18rpx 20rpx;
}

.detail-label {
  display: block;
  font-size: 20rpx;
  color: #8b7b68;
}

.detail-value {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #2f261c;
}

.card-foot {
  margin-top: 24rpx;
}

.updated-at {
  font-size: 20rpx;
  color: #8b7b68;
}

.detail-link {
  font-size: 22rpx;
  color: #0f766e;
}
