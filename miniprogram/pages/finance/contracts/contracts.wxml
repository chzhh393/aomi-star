<view class="page">
  <view class="hero">
    <view class="hero-top">
      <text class="hero-title">合同审核</text>
      <text class="hero-action" bindtap="openCandidateList">候选人总表</text>
    </view>
    <text class="hero-desc">财务账号可在这里处理待审核合同，审核通过后流转到管理员审批。</text>
  </view>

  <view class="stats-grid">
    <view class="stat-card is-pending">
      <text class="stat-value">{{stats.pending}}</text>
      <text class="stat-label">待审核</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{stats.approved}}</text>
      <text class="stat-label">已通过</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{stats.rejected}}</text>
      <text class="stat-label">已驳回</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{stats.all}}</text>
      <text class="stat-label">全部</text>
    </view>
  </view>

  <scroll-view class="filter-row" scroll-x enable-flex show-scrollbar="{{false}}">
    <view
      wx:for="{{filterOptions}}"
      wx:key="value"
      class="filter-chip {{filter === item.value ? 'is-active' : ''}}"
      data-filter="{{item.value}}"
      bindtap="onFilterChange"
    >
      {{item.label}}
    </view>
  </scroll-view>

  <view wx:if="{{loading}}" class="empty-state">
    <text class="empty-title">加载中...</text>
    <text class="empty-desc">正在获取合同审核数据</text>
  </view>

  <view wx:elif="{{!filteredContracts.length}}" class="empty-state">
    <text class="empty-title">暂无数据</text>
    <text class="empty-desc">当前筛选条件下没有可显示的合同</text>
  </view>

  <view wx:else class="list">
    <view wx:for="{{filteredContracts}}" wx:key="_id" class="contract-card">
      <view class="card-head">
        <view>
          <text class="candidate-name">{{item.displayName}}</text>
          <text class="candidate-meta">{{item.candidateNo}}</text>
        </view>
        <view class="status-group">
          <text class="status-badge finance-{{item.financeStatus || 'none'}}">{{item.financeStatusLabel}}</text>
          <text class="status-hint">{{item.workflowStatusLabel}}</text>
        </view>
      </view>

      <view class="detail-grid">
        <view class="detail-item">
          <text class="detail-label">合同名称</text>
          <text class="detail-value">{{item.contractTitle}}</text>
        </view>
        <view class="detail-item">
          <text class="detail-label">合同类型</text>
          <text class="detail-value">{{item.contractType}}</text>
        </view>
        <view class="detail-item">
          <text class="detail-label">合同文件</text>
          <text class="detail-value">{{item.contractFileName || '未填写文件名'}}</text>
        </view>
        <view class="detail-item">
          <text class="detail-label">审核人</text>
          <text class="detail-value">{{item.financeReviewer || '待处理'}}</text>
        </view>
      </view>

      <view wx:if="{{item.contractRemark}}" class="remark-box">
        <text class="remark-label">备注</text>
        <text class="remark-text">{{item.contractRemark}}</text>
      </view>

      <view class="comment-box">
        <text class="comment-label">财务意见</text>
        <textarea
          class="comment-input"
          placeholder="可填写审核意见，留空也可直接操作"
          value="{{draftComments[item._id] !== undefined ? draftComments[item._id] : item.financeComment}}"
          data-id="{{item._id}}"
          bindinput="onCommentInput"
          maxlength="200"
          auto-height
        />
      </view>

      <view wx:if="{{item.financeStatus === 'pending'}}" class="action-row">
        <button
          class="action-btn reject"
          data-id="{{item._id}}"
          data-approved="{{false}}"
          bindtap="reviewContract"
          loading="{{submittingId === item._id}}"
          disabled="{{submittingId === item._id}}"
        >
          驳回
        </button>
        <button
          class="action-btn approve"
          data-id="{{item._id}}"
          data-approved="{{true}}"
          bindtap="reviewContract"
          loading="{{submittingId === item._id}}"
          disabled="{{submittingId === item._id}}"
        >
          通过
        </button>
      </view>
    </view>
  </view>
</view>
