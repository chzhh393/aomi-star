.page {
  min-height: 100vh;
  background: #f5f1e8;
  padding: 24rpx;
  box-sizing: border-box;
}

.hero {
  background: linear-gradient(135deg, #102a1e, #1d4d36);
  color: #fff;
  padding: 32rpx;
  border-radius: 28rpx;
  box-shadow: 0 20rpx 40rpx rgba(16, 42, 30, 0.14);
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 800;
}

.hero-action {
  font-size: 22rpx;
  color: #f2c94c;
  border: 2rpx solid rgba(242, 201, 76, 0.45);
  border-radius: 999rpx;
  padding: 10rpx 20rpx;
}

.hero-desc {
  display: block;
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.82);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-top: 24rpx;
}

.stat-card {
  background: #fff;
  border-radius: 22rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  border: 2rpx solid #e7dfcf;
}

.stat-card.is-pending {
  border-color: #d4a017;
}

.stat-value {
  display: block;
  font-size: 38rpx;
  font-weight: 800;
  color: #102a1e;
}

.stat-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6d766f;
}

.filter-row {
  white-space: nowrap;
  margin-top: 24rpx;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  padding: 16rpx 28rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #415047;
  border: 2rpx solid #e6ddcc;
  font-size: 24rpx;
  font-weight: 600;
}

.filter-chip.is-active {
  background: #102a1e;
  color: #fff;
  border-color: #102a1e;
}

.empty-state {
  margin-top: 32rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 60rpx 32rpx;
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #102a1e;
}

.empty-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #7a837c;
}

.list {
  margin-top: 24rpx;
}

.contract-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 16rpx 32rpx rgba(43, 55, 48, 0.08);
}

.card-head {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.candidate-name {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #102a1e;
}

.candidate-meta {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #78827c;
}

.status-group {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.status-badge {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.finance-pending {
  background: rgba(212, 160, 23, 0.18);
  color: #a06e00;
}

.finance-approved {
  background: rgba(31, 138, 112, 0.14);
  color: #1f8a70;
}

.finance-rejected {
  background: rgba(196, 58, 58, 0.12);
  color: #b03030;
}

.finance-none {
  background: #f0ede4;
  color: #7d8079;
}

.status-hint {
  font-size: 20rpx;
  color: #7d8079;
}

.detail-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx 24rpx;
  margin-top: 24rpx;
}

.detail-item {
  min-width: 0;
}

.detail-label {
  display: block;
  font-size: 20rpx;
  color: #859087;
}

.detail-value {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #203228;
  word-break: break-all;
}

.remark-box,
.comment-box {
  margin-top: 24rpx;
  background: #f8f5ee;
  border-radius: 20rpx;
  padding: 20rpx;
}

.remark-label,
.comment-label {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  color: #506056;
}

.remark-text {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #2f4036;
  line-height: 1.6;
}

.comment-input {
  width: 100%;
  min-height: 120rpx;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #203228;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.action-btn {
  flex: 1;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 700;
  border: none;
}

.action-btn.approve {
  background: #1f8a70;
  color: #fff;
}

.action-btn.reject {
  background: #f0ede4;
  color: #8f322f;
}
