.page {
  min-height: 100vh;
  background: #f5f1e8;
  padding: 24rpx;
  box-sizing: border-box;
}

.hero,
.card,
.empty-state {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.06);
}

.hero {
  background: linear-gradient(135deg, #102a1e, #1d4d36);
  color: #fff;
}

.hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
}

.hero-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.82);
}

.section {
  margin-top: 24rpx;
}

.action-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.action-button {
  margin: 0;
  border: none;
  border-radius: 999rpx;
  padding: 0 28rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.action-button::after {
  border: none;
}

.action-primary {
  background: #102a1e;
  color: #fff;
}

.action-secondary {
  background: #e9e2d3;
  color: #102a1e;
}

.section-title {
  margin-bottom: 16rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: #102a1e;
}

.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.grid-item-full {
  grid-column: span 2;
}

.label {
  display: block;
  font-size: 22rpx;
  color: #6f7972;
}

.value {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #102a1e;
}

.row-between {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: center;
}

.align-right {
  text-align: right;
}

.empty-state {
  text-align: center;
  color: #6f7972;
  font-size: 24rpx;
}

.media-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.media-image {
  width: 100%;
  height: 200rpx;
  border-radius: 20rpx;
  background: #e5e7eb;
}

.mini-button {
  margin: 0;
  padding: 0 20rpx;
  border: none;
  border-radius: 999rpx;
  background: #102a1e;
  color: #fff;
  font-size: 22rpx;
}

.mini-button::after {
  border: none;
}

.subsection {
  margin-top: 20rpx;
}

.subsection-title {
  display: block;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #102a1e;
}

.video-item {
  margin-top: 12rpx;
}

.status-chip {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #e7f3eb;
  color: #1d4d36;
  font-size: 20rpx;
  font-weight: 700;
}

.evaluation-grid {
  margin-top: 20rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #ebe4d6;
  color: #5b5144;
  font-size: 20rpx;
}
