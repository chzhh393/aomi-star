.detail-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 10% 5%, rgba(255, 170, 77, 0.18), transparent 24%),
    radial-gradient(circle at 92% 10%, rgba(53, 211, 193, 0.18), transparent 26%),
    linear-gradient(180deg, #090d12 0%, #111a22 28%, #edf1ee 28%, #e3e9e4 100%);
  padding: 28rpx 24rpx 40rpx;
}

.hero-card,
.loading-state,
.empty-state,
.group-card {
  border-radius: 34rpx;
  border: 2rpx solid rgba(143, 159, 155, 0.22);
  box-shadow: 0 22rpx 54rpx rgba(15, 24, 27, 0.14);
}

.hero-card {
  margin-bottom: 24rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, rgba(16, 23, 31, 0.96), rgba(34, 54, 60, 0.92));
}

.hero-kicker,
.hero-title,
.hero-desc {
  display: block;
}

.hero-kicker {
  color: rgba(255, 255, 255, 0.64);
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.hero-title {
  margin-top: 14rpx;
  color: #fefcf6;
  font-size: 36rpx;
  line-height: 1.3;
  font-weight: 800;
}

.hero-desc {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 23rpx;
  line-height: 1.7;
}

.loading-state,
.empty-state {
  padding: 40rpx 32rpx;
  background: rgba(247, 249, 246, 0.92);
  margin-bottom: 24rpx;
}

.loading-title,
.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #11161d;
}

.loading-copy,
.empty-desc {
  display: block;
  margin-top: 12rpx;
  color: #62706f;
  font-size: 22rpx;
  line-height: 1.7;
}

.group-stack,
.asset-list,
.download-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.group-card {
  padding: 22rpx;
  background: rgba(255, 252, 247, 0.92);
}

.group-head {
  margin-bottom: 18rpx;
}

.group-title {
  display: block;
  color: #171214;
  font-size: 28rpx;
  font-weight: 800;
}

.group-desc {
  display: block;
  margin-top: 8rpx;
  color: #7b6e66;
  font-size: 22rpx;
  line-height: 1.6;
}

.asset-card {
  border-radius: 28rpx;
  padding: 24rpx;
  background: #ffffff;
  border: 2rpx solid rgba(147, 161, 158, 0.18);
}

.asset-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.asset-name {
  display: block;
  color: #11161d;
  font-size: 30rpx;
  font-weight: 800;
}

.asset-subtitle,
.asset-time,
.asset-summary,
.download-label,
.download-url {
  display: block;
}

.asset-subtitle,
.asset-time {
  margin-top: 8rpx;
  color: #62706f;
  font-size: 22rpx;
}

.asset-stat-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 18rpx;
}

.asset-stat {
  min-width: 110rpx;
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  background: #f6f8f6;
}

.asset-stat-value {
  display: block;
  color: #11161d;
  font-size: 30rpx;
  font-weight: 800;
}

.asset-stat-label {
  display: block;
  margin-top: 8rpx;
  color: #62706f;
  font-size: 20rpx;
}

.asset-owner {
  flex: 1;
  color: #14796f;
  font-size: 22rpx;
  text-align: right;
}

.asset-summary {
  margin-top: 16rpx;
  color: #495453;
  font-size: 22rpx;
  line-height: 1.7;
}

.download-item {
  display: flex;
  gap: 16rpx;
  align-items: center;
  justify-content: space-between;
  margin-top: 14rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: #f7faf8;
}

.download-copy {
  flex: 1;
}

.download-label {
  color: #11161d;
  font-size: 24rpx;
  font-weight: 700;
}

.download-url {
  margin-top: 8rpx;
  color: #62706f;
  font-size: 20rpx;
  line-height: 1.6;
  word-break: break-all;
}

.copy-btn {
  flex-shrink: 0;
  margin: 0;
  padding: 0 28rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: #14796f;
  color: #ffffff;
  font-size: 22rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}
