<view class="detail-page">
  <view class="hero-card">
    <view class="hero-top">
      <view>
        <text class="hero-kicker">MOVE LIBRARY</text>
        <text class="hero-title">运镜标准库</text>
        <text class="hero-desc">先看模板，再决定怎么拍。首页只保留入口，这里统一查看镜头标准。</text>
      </view>
      <view class="library-badge">{{libraryStats.templateCount}} 模板 / {{libraryStats.moveCount}} 运镜点</view>
    </view>
  </view>

  <view class="loading-state" wx:if="{{loading}}">
    <text class="loading-title">同步标准库中</text>
    <text class="loading-copy">正在拉取曲目库视觉建议和模板信息</text>
  </view>

  <view class="library-list" wx:if="{{!loading && standardLibrary.length}}">
    <view
      class="library-card"
      wx:for="{{standardLibrary}}"
      wx:key="key"
      bindtap="showLibraryAdvice"
      data-track-name="{{item.trackName}}"
      data-scene="{{item.scene}}"
      data-rhythm="{{item.rhythm}}"
      data-moves="{{item.movesText}}"
    >
      <view class="library-head">
        <text class="library-name">{{item.trackName}}</text>
        <text class="library-source">{{item.sourceLabel}}</text>
      </view>
      <text class="library-scene">{{item.scene}}</text>
      <text class="library-rhythm">{{item.rhythm}}</text>
      <view class="library-tag-row">
        <text class="library-tag" wx:for="{{item.moves}}" wx:for-item="moveItem" wx:key="*this">{{moveItem}}</text>
      </view>
      <text class="library-style">{{item.styling}}</text>
      <text class="library-link">点击查看完整建议</text>
    </view>
  </view>

  <view class="empty-state" wx:if="{{!loading && !standardLibrary.length}}">
    <text class="empty-title">暂无运镜模板</text>
    <text class="empty-desc">标准库同步完成后，这里会展示模板、场景和镜头建议。</text>
  </view>
</view>
