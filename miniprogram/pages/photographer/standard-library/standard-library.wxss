.detail-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 10% 5%, rgba(255, 170, 77, 0.18), transparent 24%),
    radial-gradient(circle at 92% 10%, rgba(53, 211, 193, 0.18), transparent 26%),
    linear-gradient(180deg, #090d12 0%, #111a22 28%, #edf1ee 28%, #e3e9e4 100%);
  padding: 28rpx 24rpx 40rpx;
}

.hero-card,
.loading-state,
.empty-state,
.library-card {
  border-radius: 34rpx;
  border: 2rpx solid rgba(143, 159, 155, 0.22);
  box-shadow: 0 22rpx 54rpx rgba(15, 24, 27, 0.14);
}

.hero-card {
  margin-bottom: 24rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, rgba(16, 23, 31, 0.96), rgba(34, 54, 60, 0.92));
}

.hero-top {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.hero-kicker,
.hero-title,
.hero-desc {
  display: block;
}

.hero-kicker {
  color: rgba(255, 255, 255, 0.64);
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.hero-title {
  margin-top: 14rpx;
  color: #fefcf6;
  font-size: 36rpx;
  line-height: 1.3;
  font-weight: 800;
}

.hero-desc {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 23rpx;
  line-height: 1.7;
}

.library-badge {
  flex-shrink: 0;
  align-self: flex-start;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(35, 193, 176, 0.12);
  color: #d8f4f0;
  font-size: 20rpx;
  font-weight: 700;
}

.loading-state,
.empty-state {
  padding: 40rpx 32rpx;
  background: rgba(247, 249, 246, 0.92);
}

.loading-title,
.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #11161d;
}

.loading-copy,
.empty-desc {
  display: block;
  margin-top: 12rpx;
  color: #62706f;
  font-size: 22rpx;
  line-height: 1.7;
}

.library-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.library-card {
  padding: 24rpx;
  background: #ffffff;
}

.library-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.library-name {
  display: block;
  color: #11161d;
  font-size: 30rpx;
  font-weight: 800;
}

.library-source,
.library-scene,
.library-rhythm,
.library-style,
.library-link {
  display: block;
}

.library-source {
  color: #14796f;
  font-size: 20rpx;
  font-weight: 700;
  text-align: right;
}

.library-scene,
.library-rhythm,
.library-style {
  margin-top: 12rpx;
  color: #4f5c5b;
  font-size: 22rpx;
  line-height: 1.7;
}

.library-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.library-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(35, 193, 176, 0.12);
  color: #14796f;
  font-size: 20rpx;
  font-weight: 700;
}

.library-link {
  margin-top: 14rpx;
  color: #d56d1e;
  font-size: 22rpx;
  font-weight: 700;
}
