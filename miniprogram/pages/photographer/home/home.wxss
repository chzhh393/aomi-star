.workspace-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background:
    radial-gradient(circle at 10% 5%, rgba(255, 170, 77, 0.18), transparent 24%),
    radial-gradient(circle at 92% 10%, rgba(53, 211, 193, 0.18), transparent 26%),
    linear-gradient(180deg, #090d12 0%, #111a22 28%, #edf1ee 28%, #e3e9e4 100%);
  padding: 28rpx 24rpx 40rpx;
}

.page-glow {
  position: absolute;
  border-radius: 999rpx;
  filter: blur(20rpx);
  opacity: 0.9;
  pointer-events: none;
}

.page-glow-a {
  width: 240rpx;
  height: 240rpx;
  background: rgba(255, 159, 67, 0.22);
  top: 58rpx;
  left: -52rpx;
}

.page-glow-b {
  width: 320rpx;
  height: 320rpx;
  background: rgba(36, 189, 170, 0.18);
  top: 160rpx;
  right: -120rpx;
}

.workspace-header,
.hero-card,
.panel-card,
.tabs-card,
.candidate-card,
.loading-state,
.empty-state {
  position: relative;
  z-index: 1;
  border-radius: 34rpx;
  border: 2rpx solid rgba(143, 159, 155, 0.22);
  box-shadow: 0 22rpx 54rpx rgba(15, 24, 27, 0.14);
}

.workspace-header {
  padding: 34rpx 32rpx;
  background: rgba(247, 249, 246, 0.92);
  margin-bottom: 24rpx;
}

.workspace-header::before {
  content: '';
  position: absolute;
  top: 24rpx;
  left: 32rpx;
  width: 148rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #ff9f43 0%, #23c1b0 100%);
}

.header-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 14rpx;
}

.header-tag {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
}

.header-kicker {
  color: #6f7a79;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.header-title {
  display: block;
  margin-top: 24rpx;
  color: #11161d;
  font-size: 48rpx;
  line-height: 1.18;
  font-weight: 800;
}

.header-subtitle {
  display: block;
  margin-top: 14rpx;
  color: #5a6766;
  font-size: 24rpx;
  line-height: 1.7;
}

.hero-card {
  margin-bottom: 24rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, rgba(16, 23, 31, 0.96), rgba(34, 54, 60, 0.92));
  border-color: rgba(255, 255, 255, 0.08);
}

.hero-kicker,
.hero-title,
.hero-desc,
.hero-metric-label {
  display: block;
}

.hero-kicker {
  color: rgba(255, 255, 255, 0.64);
  font-size: 22rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.hero-title {
  margin-top: 14rpx;
  color: #fefcf6;
  font-size: 36rpx;
  line-height: 1.3;
  font-weight: 800;
}

.hero-desc {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 23rpx;
  line-height: 1.7;
}

.hero-metrics {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.hero-metric {
  padding: 22rpx 16rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.08);
  text-align: center;
}

.hero-metric-value {
  display: block;
  color: #ffcf7d;
  font-size: 40rpx;
  line-height: 1;
  font-weight: 800;
}

.hero-metric-label {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 20rpx;
}

.photo-card-grid {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.photo-summary-card {
  border-radius: 30rpx;
  padding: 24rpx;
  background: rgba(247, 249, 246, 0.92);
  border: 2rpx solid rgba(143, 159, 155, 0.22);
  box-shadow: 0 16rpx 36rpx rgba(15, 24, 27, 0.1);
}

.photo-card-title {
  display: block;
  color: #11161d;
  font-size: 30rpx;
  font-weight: 800;
}

.photo-card-summary {
  display: block;
  margin-top: 10rpx;
  color: #d56d1e;
  font-size: 32rpx;
  font-weight: 800;
}

.photo-card-detail {
  display: block;
  margin-top: 10rpx;
  color: #61706f;
  font-size: 22rpx;
  line-height: 1.7;
}

.photo-card-link {
  display: block;
  margin-top: 12rpx;
  color: #14796f;
  font-size: 22rpx;
  font-weight: 700;
}

.panel-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  background: rgba(247, 249, 246, 0.92);
}

.panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.panel-title {
  display: block;
  color: #11161d;
  font-size: 32rpx;
  font-weight: 800;
}

.panel-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #62706f;
  font-size: 22rpx;
  line-height: 1.65;
}

.library-badge {
  flex-shrink: 0;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(35, 193, 176, 0.12);
  color: #14796f;
  font-size: 20rpx;
  font-weight: 700;
}

.radar-list,
.asset-list,
.library-list,
.candidate-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.group-stack {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.group-card {
  border-radius: 28rpx;
  padding: 22rpx;
  background: rgba(255, 252, 247, 0.92);
  border: 2rpx solid rgba(199, 185, 165, 0.28);
}

.group-head {
  margin-bottom: 18rpx;
}

.group-title {
  display: block;
  color: #171214;
  font-size: 28rpx;
  font-weight: 800;
}

.group-desc {
  display: block;
  margin-top: 8rpx;
  color: #7b6e66;
  font-size: 22rpx;
  line-height: 1.6;
}

.radar-card,
.asset-card,
.library-card {
  border-radius: 28rpx;
  padding: 24rpx;
  background: #ffffff;
  border: 2rpx solid rgba(147, 161, 158, 0.18);
}

.radar-head,
.asset-head,
.candidate-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.radar-name,
.asset-name,
.library-name,
.candidate-name {
  display: block;
  color: #11161d;
  font-size: 30rpx;
  font-weight: 800;
}

.radar-subtitle,
.asset-subtitle,
.library-source {
  display: block;
  margin-top: 8rpx;
  color: #6d7777;
  font-size: 21rpx;
}

.radar-status-box {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.radar-urgency {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 159, 67, 0.14);
  color: #b36211;
  font-size: 20rpx;
  font-weight: 700;
}

.radar-status,
.candidate-status {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.status-shoot {
  background: rgba(255, 95, 86, 0.14);
  color: #b63f36;
}

.status-edit {
  background: rgba(91, 138, 255, 0.14);
  color: #335ac2;
}

.status-deliver {
  background: rgba(35, 193, 176, 0.14);
  color: #157b70;
}

.radar-meta-row,
.library-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.meta-pill,
.library-tag {
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(17, 22, 29, 0.06);
  color: #445051;
  font-size: 20rpx;
}

.radar-info-grid,
.candidate-info-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx 18rpx;
  margin-top: 18rpx;
}

.info-row {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.info-label {
  color: #7c8685;
  font-size: 20rpx;
}

.info-value {
  color: #1e262c;
  font-size: 22rpx;
  line-height: 1.5;
  word-break: break-all;
}

.radar-focus,
.asset-summary,
.library-scene,
.library-rhythm,
.library-style {
  display: block;
  margin-top: 16rpx;
  color: #4d5a59;
  font-size: 22rpx;
  line-height: 1.7;
}

.asset-time {
  color: #7c8685;
  font-size: 20rpx;
}

.asset-stat-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 18rpx;
}

.asset-stat {
  min-width: 110rpx;
  padding: 16rpx;
  border-radius: 22rpx;
  background: rgba(17, 22, 29, 0.05);
  text-align: center;
}

.asset-stat-value {
  display: block;
  color: #182029;
  font-size: 34rpx;
  font-weight: 800;
}

.asset-stat-label {
  display: block;
  margin-top: 8rpx;
  color: #70797a;
  font-size: 20rpx;
}

.asset-owner {
  flex: 1;
  min-width: 0;
  color: #1a7b70;
  font-size: 22rpx;
  line-height: 1.5;
}

.download-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 18rpx;
}

.download-item {
  display: flex;
  align-items: stretch;
  flex-direction: column;
  gap: 14rpx;
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(17, 22, 29, 0.04);
}

.download-copy {
  flex: 1;
  min-width: 0;
}

.download-label {
  display: block;
  color: #1d262d;
  font-size: 22rpx;
  font-weight: 700;
}

.download-url {
  display: block;
  margin-top: 6rpx;
  color: #647271;
  font-size: 20rpx;
  line-height: 1.6;
  word-break: break-all;
}

.copy-btn {
  margin: 0;
  flex-shrink: 0;
  width: 100%;
  height: 64rpx;
  border-radius: 999rpx;
  background: #172029;
  color: #ffffff;
  font-size: 22rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.tabs-card {
  display: flex;
  gap: 14rpx;
  margin-bottom: 24rpx;
  padding: 10rpx;
  background: rgba(247, 249, 246, 0.92);
}

.tab-item {
  flex: 1;
  min-height: 120rpx;
  padding: 22rpx 0;
  border-radius: 22rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.tab-item.active {
  background: linear-gradient(135deg, #111a22 0%, #24453f 100%);
}

.tab-text {
  color: #374343;
  font-size: 28rpx;
  font-weight: 700;
}

.tab-count {
  color: #8b6a3b;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 800;
}

.tab-item.active .tab-text,
.tab-item.active .tab-count {
  color: #ffffff;
}

.candidate-card,
.loading-state,
.empty-state {
  padding: 22rpx;
  background: rgba(247, 249, 246, 0.92);
}

.candidate-card {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.candidate-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 28rpx;
  background: #d8dfdc;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1d262d;
  font-size: 38rpx;
  font-weight: 800;
}

.candidate-content {
  flex: 1;
  min-width: 0;
}

.loading-title,
.empty-title {
  display: block;
  color: #11161d;
  font-size: 30rpx;
  font-weight: 800;
}

.loading-copy,
.empty-desc {
  display: block;
  margin-top: 10rpx;
  color: #687574;
  font-size: 22rpx;
  line-height: 1.65;
}

.empty-mark {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  background: rgba(17, 22, 29, 0.06);
  color: #1b252c;
  font-size: 26rpx;
  font-weight: 800;
  margin-bottom: 18rpx;
}

.empty-state.compact {
  padding: 18rpx 0 4rpx;
  background: transparent;
  border: 0;
  box-shadow: none;
}
