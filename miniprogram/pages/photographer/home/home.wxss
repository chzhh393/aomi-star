.workspace-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: linear-gradient(180deg, #1a1a1a 0%, #1a1a1a 36%, #f5f5f5 36%, #ffffff 100%);
  padding: 28rpx 24rpx 40rpx;
}

.workspace-header,
.hero-card,
.panel-card,
.tabs-card,
.candidate-card,
.loading-state,
.empty-state {
  position: relative;
  z-index: 1;
  border-radius: 28rpx;
  border: 2rpx solid #e5e5e5;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.workspace-header {
  padding: 30rpx;
  background: linear-gradient(135deg, #F8D55D 0%, #FADF7F 100%);
  margin-bottom: 24rpx;
  border: none;
  box-shadow: 0 20rpx 40rpx rgba(248, 213, 93, 0.3);
}

.workspace-header::before {
  display: none;
}

.header-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.header-tag {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.85);
  color: #1a1a1a;
  font-size: 24rpx;
  font-weight: 700;
}

.header-kicker {
  color: rgba(30, 20, 18, 0.72);
  font-size: 20rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.header-title {
  display: block;
  margin-top: 18rpx;
  color: #221714;
  font-size: 46rpx;
  line-height: 1.18;
  font-weight: 700;
}

.header-subtitle {
  display: block;
  margin-top: 14rpx;
  color: rgba(34, 23, 20, 0.76);
  font-size: 24rpx;
  line-height: 1.7;
}

.hero-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  background: #ffffff;
  border-color: #e5e5e5;
}

.hero-kicker,
.hero-title,
.hero-desc,
.hero-metric-label {
  display: block;
}

.hero-kicker {
  color: #7d736a;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.hero-title {
  margin-top: 14rpx;
  color: #1b1c22;
  font-size: 32rpx;
  line-height: 1.3;
  font-weight: 700;
}

.hero-desc {
  margin-top: 12rpx;
  color: #5d5751;
  font-size: 23rpx;
  line-height: 1.7;
}

.hero-metrics {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 20rpx;
}

.hero-metric {
  padding: 20rpx 16rpx;
  border-radius: 22rpx;
  background: #f9f9f9;
  text-align: center;
  border: 2rpx solid #e5e5e5;
}

.hero-metric-value {
  display: block;
  color: #F8D55D;
  font-size: 36rpx;
  line-height: 1;
  font-weight: 700;
}

.hero-metric-label {
  margin-top: 10rpx;
  color: #7d736a;
  font-size: 20rpx;
}

.photo-card-grid {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.photo-summary-card {
  border-radius: 28rpx;
  padding: 24rpx;
  background: #ffffff;
  border: 2rpx solid #e5e5e5;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.photo-card-title {
  display: block;
  color: #1b1c22;
  font-size: 28rpx;
  font-weight: 700;
}

.photo-card-summary {
  display: block;
  margin-top: 10rpx;
  color: #F8D55D;
  font-size: 32rpx;
  font-weight: 700;
}

.photo-card-detail {
  display: block;
  margin-top: 10rpx;
  color: #5d5751;
  font-size: 22rpx;
  line-height: 1.7;
}

.photo-card-link {
  display: block;
  margin-top: 12rpx;
  color: #F8D55D;
  font-size: 22rpx;
  font-weight: 600;
}

.panel-card {
  margin-bottom: 24rpx;
  padding: 24rpx;
  background: #ffffff;
}

.panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.panel-title {
  display: block;
  color: #1b1c22;
  font-size: 30rpx;
  font-weight: 700;
}

.panel-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #5d5751;
  font-size: 22rpx;
  line-height: 1.65;
}

.library-badge {
  flex-shrink: 0;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(248, 213, 93, 0.15);
  color: #996B00;
  font-size: 20rpx;
  font-weight: 700;
}

.radar-list,
.asset-list,
.library-list,
.candidate-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.group-stack {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.group-card {
  border-radius: 24rpx;
  padding: 22rpx;
  background: #f9f9f9;
  border: 2rpx solid #e5e5e5;
}

.group-head {
  margin-bottom: 18rpx;
}

.group-title {
  display: block;
  color: #1b1c22;
  font-size: 28rpx;
  font-weight: 700;
}

.group-desc {
  display: block;
  margin-top: 8rpx;
  color: #7d736a;
  font-size: 22rpx;
  line-height: 1.6;
}

.radar-card,
.asset-card,
.library-card {
  border-radius: 24rpx;
  padding: 22rpx;
  background: #ffffff;
  border: 2rpx solid #e5e5e5;
}

.radar-head,
.asset-head,
.candidate-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.radar-name,
.asset-name,
.library-name,
.candidate-name {
  display: block;
  color: #1b1c22;
  font-size: 28rpx;
  font-weight: 700;
}

.radar-subtitle,
.asset-subtitle,
.library-source {
  display: block;
  margin-top: 8rpx;
  color: #7d736a;
  font-size: 21rpx;
}

.radar-status-box {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.radar-urgency {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(248, 213, 93, 0.15);
  color: #996B00;
  font-size: 20rpx;
  font-weight: 600;
}

.radar-status,
.candidate-status {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.status-shoot {
  background: #ffe0dc;
  color: #b73724;
}

.status-edit {
  background: rgba(91, 138, 255, 0.14);
  color: #335ac2;
}

.status-deliver {
  background: #dff3dd;
  color: #2f7a2e;
}

.radar-meta-row,
.library-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.meta-pill,
.library-tag {
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: #f9f9f9;
  color: #5d5751;
  font-size: 20rpx;
  border: 2rpx solid #e5e5e5;
}

.radar-info-grid,
.candidate-info-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx 18rpx;
  margin-top: 18rpx;
}

.info-row {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.info-label {
  color: #7d736a;
  font-size: 20rpx;
}

.info-value {
  color: #1b1c22;
  font-size: 22rpx;
  line-height: 1.5;
  word-break: break-all;
}

.radar-focus,
.asset-summary,
.library-scene,
.library-rhythm,
.library-style {
  display: block;
  margin-top: 16rpx;
  color: #5d5751;
  font-size: 22rpx;
  line-height: 1.7;
}

.asset-time {
  color: #7d736a;
  font-size: 20rpx;
}

.asset-stat-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 18rpx;
}

.asset-stat {
  min-width: 110rpx;
  padding: 16rpx;
  border-radius: 22rpx;
  background: #f9f9f9;
  text-align: center;
  border: 2rpx solid #e5e5e5;
}

.asset-stat-value {
  display: block;
  color: #1b1c22;
  font-size: 32rpx;
  font-weight: 700;
}

.asset-stat-label {
  display: block;
  margin-top: 8rpx;
  color: #7d736a;
  font-size: 20rpx;
}

.asset-owner {
  flex: 1;
  min-width: 0;
  color: #F8D55D;
  font-size: 22rpx;
  line-height: 1.5;
  font-weight: 600;
}

.download-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 18rpx;
}

.download-item {
  display: flex;
  align-items: stretch;
  flex-direction: column;
  gap: 14rpx;
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  background: #f9f9f9;
  border: 2rpx solid #e5e5e5;
}

.download-copy {
  flex: 1;
  min-width: 0;
}

.download-label {
  display: block;
  color: #1b1c22;
  font-size: 22rpx;
  font-weight: 700;
}

.download-url {
  display: block;
  margin-top: 6rpx;
  color: #7d736a;
  font-size: 20rpx;
  line-height: 1.6;
  word-break: break-all;
}

.copy-btn {
  margin: 0;
  flex-shrink: 0;
  width: 100%;
  height: 64rpx;
  border-radius: 999rpx;
  background: #F8D55D;
  color: #1a1a1a;
  font-size: 22rpx;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  box-shadow: 0 8rpx 20rpx rgba(248, 213, 93, 0.3);
}

.tabs-card {
  display: flex;
  gap: 14rpx;
  margin-bottom: 24rpx;
  padding: 10rpx;
  background: #ffffff;
}

.tab-item {
  flex: 1;
  min-height: 120rpx;
  padding: 22rpx 0;
  border-radius: 22rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.tab-item.active {
  background: linear-gradient(135deg, #F8D55D 0%, #FADF7F 100%);
  box-shadow: 0 8rpx 20rpx rgba(248, 213, 93, 0.3);
}

.tab-text {
  color: #5d5751;
  font-size: 28rpx;
  font-weight: 700;
}

.tab-count {
  color: #7d736a;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 700;
}

.tab-item.active .tab-text,
.tab-item.active .tab-count {
  color: #1a1a1a;
}

.candidate-card,
.loading-state,
.empty-state {
  padding: 22rpx;
  background: #ffffff;
}

.candidate-card {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.candidate-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 28rpx;
  background: #f9f9f9;
  border: 2rpx solid #e5e5e5;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1b1c22;
  font-size: 38rpx;
  font-weight: 700;
}

.candidate-content {
  flex: 1;
  min-width: 0;
}

.loading-title,
.empty-title {
  display: block;
  color: #1b1c22;
  font-size: 30rpx;
  font-weight: 700;
}

.loading-copy,
.empty-desc {
  display: block;
  margin-top: 10rpx;
  color: #7d736a;
  font-size: 22rpx;
  line-height: 1.65;
}

.empty-mark {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  background: #f9f9f9;
  color: #1b1c22;
  font-size: 26rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
  border: 2rpx solid #e5e5e5;
}

.empty-state.compact {
  padding: 18rpx 0 4rpx;
  background: transparent;
  border: 0;
  box-shadow: none;
}
