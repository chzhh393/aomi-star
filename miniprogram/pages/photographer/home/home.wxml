<view class="workspace-page">
  <view class="page-glow page-glow-a"></view>
  <view class="page-glow page-glow-b"></view>

  <view class="workspace-header">
    <view class="header-topline">
      <view class="header-tag" style="background: {{roleConfig.accent}}">{{roleConfig.icon}} {{roleConfig.name}}</view>
      <text class="header-kicker">Visual Asset Center</text>
    </view>
    <text class="header-title">摄影/剪辑工作台</text>
    <text class="header-subtitle">根据系统任务流精准拍摄，自动接收老师高光直拍和经纪人定制需求，按主播 ID 统一归档原片、精修和可分发链接。</text>
  </view>

  <view class="hero-card">
    <view class="hero-copy">
      <text class="hero-kicker">任务流驱动拍摄</text>
      <text class="hero-title">拍摄任务、资产沉淀、运镜标准在一个工作台里闭环</text>
    </view>
    <view class="hero-metrics">
      <view class="hero-metric">
        <text class="hero-metric-value">{{taskOverview.total}}</text>
        <text class="hero-metric-label">雷达任务</text>
      </view>
      <view class="hero-metric">
        <text class="hero-metric-value">{{taskOverview.todayCount}}</text>
        <text class="hero-metric-label">今日执行</text>
      </view>
      <view class="hero-metric">
        <text class="hero-metric-value">{{taskOverview.urgentCount}}</text>
        <text class="hero-metric-label">待拍/超时</text>
      </view>
      <view class="hero-metric">
        <text class="hero-metric-value">{{taskOverview.deliveryCount}}</text>
        <text class="hero-metric-label">待分发</text>
      </view>
    </view>
  </view>

  <view class="photo-card-grid">
    <view
      wx:for="{{photographerCards}}"
      wx:key="key"
      class="photo-summary-card"
      bindtap="handleShortcut"
      data-path="{{item.path}}"
    >
      <text class="photo-card-title">{{item.title}}</text>
      <text class="photo-card-summary">{{item.summary}}</text>
      <text class="photo-card-detail">{{item.detail}}</text>
      <text class="photo-card-link">点击查看</text>
    </view>
  </view>

  <view class="tabs-card">
    <view class="tab-item {{currentTab === 'pending' ? 'active' : ''}}" bindtap="switchTab" data-tab="pending">
      <text class="tab-text">待评价</text>
      <text class="tab-count">{{pendingCount}} 人</text>
    </view>
    <view class="tab-item {{currentTab === 'reviewed' ? 'active' : ''}}" bindtap="switchTab" data-tab="reviewed">
      <text class="tab-text">已评价</text>
      <text class="tab-count">{{reviewedCount}} 人</text>
    </view>
  </view>

  <view class="candidate-list">
    <view class="loading-state" wx:if="{{loading}}">
      <text class="loading-title">同步摄影师任务中</text>
      <text class="loading-copy">正在拉取你的待拍摄和已处理名单</text>
    </view>

    <view class="empty-state" wx:if="{{!loading && candidateList.length === 0}}">
      <text class="empty-mark">PH</text>
      <text class="empty-title">暂无候选人</text>
      <text class="empty-desc">当前角色名下还没有候选人或素材任务。</text>
    </view>

    <view
      wx:for="{{candidateList}}"
      wx:key="_id"
      class="candidate-card"
      bindtap="goToDetail"
      data-path="{{item.detailPath}}"
    >
      <image wx:if="{{item.avatar}}" class="candidate-avatar" src="{{item.avatar}}" mode="aspectFill"></image>
      <view wx:else class="candidate-avatar avatar-placeholder">{{item.nameInitial}}</view>
      <view class="candidate-content">
        <view class="candidate-head">
          <text class="candidate-name">{{item.name}}</text>
          <text class="candidate-status {{item.statusClass}}">{{item.statusText}}</text>
        </view>
        <view class="candidate-info-grid">
          <view class="info-row">
            <text class="info-label">直播名</text>
            <text class="info-value">{{item.liveName || '-'}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">经纪人</text>
            <text class="info-value">{{item.assignedAgentName}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">联系电话</text>
            <text class="info-value">{{item.assignedAgentPhone}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">素材进度</text>
            <text class="info-value">{{item.assetSummary}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
