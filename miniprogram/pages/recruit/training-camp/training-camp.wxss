page {
  background: #f4f6fb;
}

.page {
  padding: 24rpx 24rpx 120rpx;
}

.hero {
  background: linear-gradient(135deg, #111111, #2b2b2b);
  border-radius: 28rpx;
  padding: 36rpx 30rpx;
  margin-bottom: 24rpx;
}

.hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 800;
  color: #ffffff;
}

.hero-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.72);
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111111;
  margin-bottom: 24rpx;
}

.section-tip {
  display: block;
  margin: -8rpx 0 24rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6b7280;
}

.invite-letter {
  margin-bottom: 24rpx;
  padding: 28rpx 26rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #fffdf7 0%, #fff7eb 100%);
  border: 2rpx solid #f2d3a2;
  border-left: 8rpx solid #f59e0b;
}

.invite-letter-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.invite-letter-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #111827;
}

.invite-letter-tag {
  font-size: 20rpx;
  line-height: 1;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: #111827;
  color: #f8d36f;
  letter-spacing: 2rpx;
  font-weight: 800;
}

.invite-letter-text {
  display: block;
  font-size: 25rpx;
  line-height: 1.9;
  color: #4a2b0b;
  white-space: pre-wrap;
  text-align: left;
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 14rpx 0;
  border-bottom: 2rpx solid #f0f1f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #6b7280;
}

.info-value {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  color: #111827;
  font-weight: 600;
}

.multiline {
  white-space: pre-wrap;
}

.decision-row {
  display: flex;
  gap: 16rpx;
}

.decision-btn {
  flex: 1;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  background: #eef2ff;
  color: #3949ab;
  font-size: 28rpx;
  font-weight: 700;
}

.decision-btn.reject {
  background: #fff1f2;
  color: #d14343;
}

.decision-btn.active {
  box-shadow: inset 0 0 0 4rpx currentColor;
}

.upload-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.upload-box {
  width: calc(50% - 8rpx);
  height: 220rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  border: 2rpx dashed #cbd5e1;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.upload-box.full {
  width: 100%;
}

.upload-image {
  width: 100%;
  height: 100%;
}

.upload-text {
  font-size: 24rpx;
  color: #64748b;
  text-align: center;
  padding: 0 20rpx;
}

.form-input,
.form-textarea {
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 16rpx;
  background: #f8fafc;
  border-radius: 18rpx;
  font-size: 28rpx;
  color: #111827;
  border: 2rpx solid #e2e8f0;
}

.region-picker {
  margin-bottom: 16rpx;
}

.region-picker-inner {
  min-height: 96rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  background: #f8fafc;
  border-radius: 18rpx;
  border: 2rpx solid #e2e8f0;
  font-size: 28rpx;
  color: #94a3b8;
}

.region-picker-inner.selected {
  color: #111827;
}

.form-input {
  height: 96rpx;
  line-height: 96rpx;
  padding: 0 24rpx;
}

.form-textarea {
  min-height: 220rpx;
  padding: 24rpx;
  line-height: 1.7;
}

.submit-btn {
  margin-top: 24rpx;
  height: 92rpx;
  border-radius: 46rpx;
  background: linear-gradient(135deg, #0f172a, #2563eb);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
}

.loading {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6b7280;
  font-size: 28rpx;
}
