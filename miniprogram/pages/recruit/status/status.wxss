/* pages/recruit/status/status.wxss */
/* 报名状态页 - 街头运动风格 */

/* ==================== 主容器 ==================== */
.container {
  min-height: 100vh;
  background: #F0F0F0;
  padding: 0 0 120rpx;
}

/* ==================== 顶部横幅 ==================== */
.header-banner {
  background: #000000;
  padding: 48rpx 32rpx 32rpx;
  position: relative;
  overflow: hidden;
}

.banner-slash {
  position: absolute;
  top: 0;
  right: -40rpx;
  width: 200rpx;
  height: 100%;
  background: #13E8DD;
  transform: skewX(-15deg);
}

.banner-text {
  font-size: 48rpx;
  font-weight: 900;
  color: #FFFFFF;
  letter-spacing: 4rpx;
  position: relative;
  z-index: 1;
  display: block;
  text-transform: uppercase;
}

.banner-subtitle {
  font-size: 24rpx;
  color: #999999;
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 8rpx;
}

/* ==================== 状态卡片 ==================== */
.status-card {
  background: #FFFFFF;
  margin: 24rpx;
  padding: 40rpx 32rpx;
  border: 4rpx solid #000000;
  text-align: center;
  position: relative;
}

.status-icon-wrapper {
  margin-bottom: 20rpx;
}

.status-icon {
  font-size: 80rpx;
}

.status-title {
  font-size: 36rpx;
  font-weight: 900;
  color: #000000;
  margin-bottom: 16rpx;
}

.status-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

.notice-card {
  background: #FFFFFF;
  margin: 0 24rpx 24rpx;
  padding: 32rpx;
  border: 4rpx solid #000000;
}

.notice-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #000000;
  margin-bottom: 20rpx;
}

.notice-content {
  font-size: 24rpx;
  line-height: 1.9;
  color: #333333;
  white-space: pre-wrap;
}

.todo-card {
  background: #ffffff;
  margin: 0 24rpx 24rpx;
  padding: 32rpx;
  border: 4rpx solid #000000;
}

.todo-label-text {
  color: #000000;
}

.todo-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #000000;
  margin-bottom: 24rpx;
}

.todo-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #ededed;
}

.todo-row:last-of-type {
  border-bottom: none;
}

.todo-key {
  font-size: 26rpx;
  color: #666666;
  font-weight: 700;
  flex-shrink: 0;
}

.todo-value {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  color: #111111;
  font-weight: 700;
}

.todo-multiline {
  white-space: pre-wrap;
}

.todo-panel {
  margin-top: 24rpx;
  padding: 28rpx 26rpx;
  background: linear-gradient(180deg, #fffdf7 0%, #fff7eb 100%);
  border: 2rpx solid #f2d3a2;
  border-left: 8rpx solid #f59e0b;
}

.todo-panel-muted {
  background: #faf7f2;
  border-color: #eadfcd;
  border-left-color: #a3a3a3;
}

.todo-panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.todo-panel-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #111111;
}

.todo-panel-tag {
  font-size: 20rpx;
  line-height: 1;
  padding: 10rpx 14rpx;
  background: #111111;
  color: #f8d36f;
  letter-spacing: 2rpx;
  font-weight: 900;
}

.todo-panel-content {
  display: block;
  font-size: 26rpx;
  line-height: 1.95;
  color: #33240f;
  white-space: pre-wrap;
  text-align: left;
}

.todo-panel-content-muted {
  color: #4b5563;
}

.todo-btn {
  margin-top: 28rpx;
  height: 88rpx;
  line-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0;
  background: #000000;
  color: #13E8DD;
  font-size: 30rpx;
  font-weight: 900;
  text-align: center;
}

.todo-btn-row {
  margin-top: 28rpx;
  display: flex;
  gap: 20rpx;
}

.todo-btn-half {
  margin-top: 0;
  flex: 1;
  min-width: 0;
}

.workspace-entry {
  margin-top: 28rpx;
  padding: 24rpx;
  background: #f6f6f6;
  border: 2rpx solid #d4d4d4;
}

.workspace-entry-head {
  margin-bottom: 20rpx;
}

.workspace-entry-actions {
  display: flex;
  gap: 16rpx;
}

.workspace-entry-title {
  display: block;
  font-size: 28rpx;
  font-weight: 900;
  color: #000000;
}

.workspace-entry-copy {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #666666;
}

.workspace-main-btn {
  margin-top: 0;
  flex: 1;
  background: #13E8DD;
  color: #000000;
}

.workspace-sub-btn {
  margin-top: 0;
  flex: 1;
  background: #000000;
  color: #13E8DD;
}

/* ==================== 进度块 ==================== */
.progress-block {
  background: #000000;
  margin: 0 24rpx 24rpx;
  padding: 32rpx;
}

.block-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 32rpx;
}

.label-slash {
  width: 6rpx;
  height: 32rpx;
  background: #13E8DD;
}

.label-text {
  font-size: 24rpx;
  font-weight: 900;
  color: #FFFFFF;
  letter-spacing: 3rpx;
}

.progress-steps {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  width: 92rpx;
  flex-shrink: 0;
}

.step-icon-box {
  width: 72rpx;
  height: 72rpx;
  background: #333333;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  border: 4rpx solid #333333;
}

.step-item.active .step-icon-box {
  background: #13E8DD;
  border-color: #13E8DD;
}

.step-icon {
  font-size: 36rpx;
}

.step-label {
  font-size: 22rpx;
  color: #666666;
  font-weight: 600;
  line-height: 1.45;
  text-align: center;
  min-height: 64rpx;
  width: 100%;
  word-break: break-all;
}

.step-item.active .step-label {
  color: #13E8DD;
  font-weight: 900;
}

.step-line {
  flex: 1;
  height: 4rpx;
  background: #333333;
  position: relative;
  margin: 34rpx 12rpx 0;
}

.step-line-fill {
  height: 100%;
  width: 0;
  background: #13E8DD;
  transition: width 0.5s ease;
}

.step-line-fill.active {
  width: 100%;
}

/* ==================== 审核信息块 ==================== */
.review-block {
  background: #FFFFFF;
  margin: 0 24rpx 24rpx;
  padding: 32rpx;
  border: 4rpx solid #000000;
}

.review-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #E0E0E0;
}

.review-item:last-child {
  border-bottom: none;
}

.review-label {
  font-size: 26rpx;
  color: #666666;
  font-weight: 600;
}

.review-value {
  font-size: 26rpx;
  color: #000000;
  font-weight: 700;
  max-width: 60%;
  text-align: right;
}

/* ==================== 面试信息块 ==================== */
.interview-block {
  background: #FFFFFF;
  margin: 0 24rpx 24rpx;
  padding: 32rpx;
  border: 4rpx solid #000000;
}

.interview-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #000000;
  margin-bottom: 24rpx;
}

.interview-card {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.interview-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.interview-icon {
  font-size: 36rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.interview-info {
  flex: 1;
}

.interview-label {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 4rpx;
}

.interview-value {
  font-size: 30rpx;
  color: #000000;
  font-weight: 700;
}

/* ==================== 面试详情入口 ==================== */
.interview-detail-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 24rpx;
  padding: 20rpx;
  background: #13E8DD;
}

.interview-detail-text {
  font-size: 26rpx;
  font-weight: 900;
  color: #000000;
}

.interview-detail-arrow {
  font-size: 28rpx;
  font-weight: 900;
  color: #000000;
}

/* ==================== 操作按钮 ==================== */
.actions-block {
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-btn {
  width: 100%;
  height: 88rpx;
  border: none;
  font-size: 28rpx;
  font-weight: 900;
  border-radius: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background: #13E8DD;
  color: #000000;
}

.btn-secondary {
  background: #FFFFFF;
  color: #000000;
  border: 4rpx solid #000000;
}

.btn-ghost {
  background: transparent;
  color: #000000;
  border: 4rpx solid #000000;
}

.btn-primary:active {
  opacity: 0.9;
}

.btn-secondary:active,
.btn-ghost:active {
  opacity: 0.8;
}

.action-row {
  display: flex;
  gap: 16rpx;
}

.action-row .action-btn {
  flex: 1;
}

.btn-text {
  font-size: 28rpx;
  font-weight: 900;
}

/* ==================== 温馨提示 ==================== */
.tips-block {
  margin: 24rpx;
  padding: 24rpx;
  background: rgba(19, 232, 221, 0.1);
  border-left: 6rpx solid #13E8DD;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
  flex: 1;
}

/* ==================== 空状态 ==================== */
.empty-state {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F0F0F0;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 900;
  color: #999999;
}
