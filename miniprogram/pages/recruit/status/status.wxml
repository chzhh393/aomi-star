<!--pages/recruit/status/status.wxml-->
<!--报名状态页 - 街头运动风格-->
<view class="container" wx:if="{{!loading && candidate}}">

  <!-- 顶部横幅 -->
  <view class="header-banner">
    <view class="banner-slash"></view>
    <text class="banner-text">CANDIDATE</text>
    <text class="banner-subtitle">主播候选人</text>
  </view>

  <!-- 状态卡片：审核通过时显示面试流程入口 -->
  <view class="status-card status-card-approved" wx:if="{{candidate.status === 'approved'}}" bindtap="viewInterviewInvite">
    <view class="status-icon-wrapper">
      <text class="status-icon">🎉</text>
    </view>
    <view class="status-title">恭喜，审核已通过！</view>
    <view class="status-desc">请查看面试流程，提前做好准备</view>
    <view class="interview-detail-btn" style="margin-top: 24rpx;">
      <text class="interview-detail-text">查看面试流程</text>
      <text class="interview-detail-arrow">→</text>
    </view>
  </view>

  <!-- 状态卡片：其他状态 -->
  <view class="status-card" wx:else>
    <view class="status-icon-wrapper">
      <text class="status-icon">{{statusInfo.title.includes('成功') || statusInfo.title.includes('通过') || statusInfo.title.includes('恭喜') ? '✅' : statusInfo.title.includes('遗憾') ? '❌' : '⏳'}}</text>
    </view>
    <view class="status-title">{{statusInfo.title}}</view>
    <view class="status-desc">{{statusInfo.desc}}</view>
  </view>

  <view class="notice-card" wx:if="{{candidate.trainingCampNotice && !candidate.trainingCampTodo}}">
    <view class="block-label">
      <view class="label-slash"></view>
      <text class="label-text">CAMP NOTICE</text>
    </view>
    <view class="notice-title">{{candidate.trainingCampNotice.title}}</view>
    <view class="notice-content">{{candidate.trainingCampNotice.content}}</view>
  </view>

  <view class="todo-card" wx:if="{{candidate.trainingCampTodo}}">
    <view class="block-label">
      <view class="label-slash"></view>
      <text class="label-text todo-label-text">TRAINING TODO</text>
    </view>
    <view class="todo-title">训练营入营待办</view>
    <view class="todo-row">
      <text class="todo-key">状态</text>
      <text class="todo-value">{{trainingCampTodoStatusText}}</text>
    </view>
    <view class="todo-row">
      <text class="todo-key">训练营类型</text>
      <text class="todo-value">{{displayCampType || '-'}}</text>
    </view>
    <view class="todo-row">
      <text class="todo-key">入营时间</text>
      <text class="todo-value">{{candidate.trainingCampTodo.startDate || '-'}} {{candidate.trainingCampTodo.startTime || ''}}</text>
    </view>
    <view class="todo-panel" wx:if="{{candidate.trainingCampTodo.invitationContent}}">
      <view class="todo-panel-head">
        <text class="todo-panel-title">训练营邀请函</text>
        <text class="todo-panel-tag">OFFICIAL NOTICE</text>
      </view>
      <rich-text class="todo-panel-content" nodes="{{invitationRichText}}"></rich-text>
    </view>
    <view class="todo-panel todo-panel-muted" wx:if="{{candidate.trainingCampTodo.remark}}">
      <view class="todo-panel-head">
        <text class="todo-panel-title">备注</text>
      </view>
      <text class="todo-panel-content todo-panel-content-muted">{{candidate.trainingCampTodo.remark}}</text>
    </view>
    <view class="todo-panel todo-panel-muted" wx:if="{{candidate.trainingCampTodo.rejectReason}}">
      <view class="todo-panel-head">
        <text class="todo-panel-title">拒绝原因</text>
      </view>
      <text class="todo-panel-content todo-panel-content-muted">{{candidate.trainingCampTodo.rejectReason}}</text>
    </view>
    <view class="todo-btn-row" wx:if="{{canHandleTrainingCampTodo}}">
      <button class="todo-btn todo-btn-half" bindtap="confirmTrainingCampTodo">确认入营</button>
      <button class="todo-btn todo-btn-half" bindtap="rejectTrainingCampTodo">拒绝入营</button>
    </view>
    <view class="workspace-entry" wx:if="{{candidate.status === 'training' || candidate.status === 'signed' || candidate.status === 'active'}}">
      <view class="workspace-entry-head">
        <text class="workspace-entry-title">主播工作入口</text>
        <text class="workspace-entry-copy">主播中台作为主入口，训练记录保留为快捷操作。</text>
      </view>
      <view class="workspace-entry-actions">
        <button class="todo-btn todo-btn-half workspace-main-btn" bindtap="enterAnchorWorkspace">进入主播中台</button>
        <button class="todo-btn todo-btn-half workspace-sub-btn" wx:if="{{candidate.status === 'training'}}" bindtap="goToTrainingDaily">快捷记录训练</button>
      </view>
    </view>
  </view>

  <!-- 进度条 -->
  <view class="progress-block">
    <view class="block-label">
      <view class="label-slash"></view>
      <text class="label-text">PROGRESS</text>
    </view>

    <view class="progress-steps">
      <block wx:for="{{statusSteps}}" wx:key="key">
        <view class="step-item {{currentStep >= index + 1 ? 'active' : ''}}">
          <view class="step-icon-box">
            <text class="step-icon">{{item.icon}}</text>
          </view>
          <text class="step-label">{{item.label}}</text>
        </view>
        <view class="step-line" wx:if="{{index < statusSteps.length - 1}}">
          <view class="step-line-fill {{currentStep > index + 1 ? 'active' : ''}}"></view>
        </view>
      </block>
    </view>
  </view>

  <!-- 审核信息 -->
  <view class="review-block" wx:if="{{candidate.hrReview}}">
    <view class="block-label">
      <view class="label-slash"></view>
      <text class="label-text">REVIEW INFO</text>
    </view>

    <view class="review-item">
      <view class="review-label">审核意见</view>
      <view class="review-value">{{candidate.hrReview.comment}}</view>
    </view>

    <view class="review-item" wx:if="{{candidate.hrReview.suggestedSalary}}">
      <view class="review-label">建议薪资</view>
      <view class="review-value">{{candidate.hrReview.suggestedSalary}}</view>
    </view>

    <view class="review-item" wx:if="{{candidate.hrReview.interviewDate}}">
      <view class="review-label">面试时间</view>
      <view class="review-value">{{candidate.hrReview.interviewDate}}</view>
    </view>

    <view class="review-item" wx:if="{{candidate.hrReview.reviewerName}}">
      <view class="review-label">审核人</view>
      <view class="review-value">{{candidate.hrReview.reviewerName}}</view>
    </view>

    <view class="review-item" wx:if="{{candidate.hrReview.reviewAt}}">
      <view class="review-label">审核时间</view>
      <view class="review-value">{{candidate.hrReview.reviewAt}}</view>
    </view>
  </view>

  <!-- 面试信息 -->
  <view class="interview-block" wx:if="{{candidate.interview && candidate.status === 'interview_scheduled'}}">
    <view class="interview-title">面试信息</view>
    <view class="interview-card">
      <view class="interview-row">
        <text class="interview-icon">📅</text>
        <view class="interview-info">
          <view class="interview-label">面试日期</view>
          <view class="interview-value">{{candidate.interview.date}}</view>
        </view>
      </view>

      <view class="interview-row">
        <text class="interview-icon">🕐</text>
        <view class="interview-info">
          <view class="interview-label">面试时间</view>
          <view class="interview-value">{{candidate.interview.time}}</view>
        </view>
      </view>

      <view class="interview-row" wx:if="{{candidate.interview.location}}">
        <text class="interview-icon">📍</text>
        <view class="interview-info">
          <view class="interview-label">面试地点</view>
          <view class="interview-value">{{candidate.interview.location}}</view>
        </view>
      </view>

      <view class="interview-row" wx:if="{{candidate.interview.interviewers && candidate.interview.interviewers.length > 0}}">
        <text class="interview-icon">👤</text>
        <view class="interview-info">
          <view class="interview-label">面试官</view>
          <view class="interview-value">{{candidate.interview.interviewers.join('、')}}</view>
        </view>
      </view>

      <view class="interview-row" wx:if="{{candidate.interview.notes}}">
        <text class="interview-icon">📝</text>
        <view class="interview-info">
          <view class="interview-label">备注</view>
          <view class="interview-value">{{candidate.interview.notes}}</view>
        </view>
      </view>
    </view>

    <view class="interview-detail-btn" bindtap="viewInterviewInvite">
      <text class="interview-detail-text">查看完整面试流程</text>
      <text class="interview-detail-arrow">→</text>
    </view>
  </view>

  <!-- 快捷操作 -->
  <view class="actions-block">
    <view class="action-row">
      <button class="action-btn btn-secondary" bindtap="viewDetail">
        <text class="btn-text">查看详情</text>
      </button>

      <button class="action-btn btn-ghost" bindtap="onRefresh">
        <text class="btn-text">刷新状态</text>
      </button>
    </view>
  </view>

  <!-- 温馨提示 -->
  <view class="tips-block">
    <view class="tip-item" wx:if="{{candidate.status === 'pending'}}">
      <text class="tip-icon">📋</text>
      <text class="tip-text">审核期间可随时查看进度，无需重复提交</text>
    </view>
    <view class="tip-item" wx:if="{{candidate.status === 'approved'}}">
      <text class="tip-icon">🎉</text>
      <text class="tip-text">审核已通过，HR将尽快为您安排面试，请保持手机畅通</text>
    </view>
    <view class="tip-item" wx:if="{{candidate.status === 'interview_scheduled'}}">
      <text class="tip-icon">💡</text>
      <text class="tip-text">请按时参加面试，提前做好准备</text>
    </view>
    <view class="tip-item" wx:if="{{candidate.status === 'signed'}}">
      <text class="tip-icon">👏</text>
      <text class="tip-text">欢迎加入！点击按钮进入主播工作台</text>
    </view>
  </view>

</view>

<!-- 加载中 -->
<view class="empty-state" wx:if="{{loading}}">
  <text class="empty-text">加载中...</text>
</view>
