/* pages/recruit/interview-invite/interview-invite.wxss */
/* 面试邀请详情页 - 街头运动风格 */

/* ==================== 主容器 ==================== */
.container {
  min-height: 100vh;
  background: #F0F0F0;
  padding: 0 0 120rpx;
}

/* ==================== 顶部横幅 ==================== */
.header-banner {
  background: #000000;
  padding: 48rpx 32rpx 32rpx;
  position: relative;
  overflow: hidden;
}

.banner-slash {
  position: absolute;
  top: 0;
  right: -40rpx;
  width: 200rpx;
  height: 100%;
  background: #13E8DD;
  transform: skewX(-15deg);
}

.banner-text {
  font-size: 48rpx;
  font-weight: 900;
  color: #FFFFFF;
  letter-spacing: 4rpx;
  position: relative;
  z-index: 1;
  display: block;
  text-transform: uppercase;
}

.banner-subtitle {
  font-size: 24rpx;
  color: #999999;
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 8rpx;
}

/* ==================== 欢迎卡片 ==================== */
.welcome-card {
  background: #FFFFFF;
  margin: 24rpx;
  padding: 40rpx 32rpx;
  border: 4rpx solid #000000;
}

.welcome-title {
  font-size: 36rpx;
  font-weight: 900;
  color: #000000;
  margin-bottom: 16rpx;
}

.welcome-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
}

/* ==================== 面试流程 ==================== */
.flow-block {
  background: #000000;
  margin: 0 24rpx 24rpx;
  padding: 32rpx;
}

.block-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 32rpx;
}

.label-slash {
  width: 6rpx;
  height: 32rpx;
  background: #13E8DD;
}

.label-text {
  font-size: 24rpx;
  font-weight: 900;
  color: #FFFFFF;
  letter-spacing: 3rpx;
}

.flow-item {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #222222;
}

.flow-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.flow-number {
  font-size: 48rpx;
  font-weight: 900;
  color: #13E8DD;
  line-height: 1;
  flex-shrink: 0;
  width: 72rpx;
}

.flow-content {
  flex: 1;
}

.flow-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.flow-desc {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.6;
}

.flow-detail {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 4rpx;
}

.detail-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.detail-dot {
  width: 10rpx;
  height: 10rpx;
  background: #13E8DD;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 12rpx;
}

.detail-text {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.6;
}

/* ==================== 面试信息 ==================== */
.info-block {
  background: #FFFFFF;
  margin: 0 24rpx 24rpx;
  padding: 32rpx;
  border: 4rpx solid #000000;
}

.info-card {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.info-icon {
  font-size: 36rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.info-icon-box {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 2rpx;
  background: #000000;
  border: 2rpx solid #13E8DD;
}

.info-icon-text {
  font-size: 28rpx;
  line-height: 1;
}

.info-content {
  flex: 1;
}

.info-label {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 4rpx;
}

.info-value {
  font-size: 30rpx;
  color: #000000;
  font-weight: 700;
}

.copy-btn {
  font-size: 22rpx;
  color: #13E8DD;
  font-weight: 700;
  background: #000000;
  padding: 8rpx 20rpx;
  flex-shrink: 0;
  align-self: center;
}

/* ==================== 底部提示 ==================== */
.footer-block {
  margin: 0 24rpx 24rpx;
  padding: 24rpx;
  background: rgba(19, 232, 221, 0.1);
  border-left: 6rpx solid #13E8DD;
}

.footer-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.footer-highlight {
  font-size: 26rpx;
  color: #000000;
  font-weight: 700;
  line-height: 1.6;
}

/* ==================== 操作按钮 ==================== */
.actions-block {
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-btn {
  width: 100%;
  height: 88rpx;
  border: none;
  font-size: 28rpx;
  font-weight: 900;
  border-radius: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background: #13E8DD;
  color: #000000;
}

.btn-ghost {
  background: transparent;
  color: #000000;
  border: 4rpx solid #000000;
}

.btn-primary:active {
  opacity: 0.9;
}

.btn-ghost:active {
  opacity: 0.8;
}

.btn-text {
  font-size: 28rpx;
  font-weight: 900;
}

/* ==================== 空状态 ==================== */
.empty-state {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F0F0F0;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 900;
  color: #999999;
}
