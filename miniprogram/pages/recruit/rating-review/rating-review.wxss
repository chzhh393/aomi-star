.rating-review-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(250, 188, 61, 0.16), transparent 28%),
    linear-gradient(180deg, #f5f1e8 0%, #f2f4f7 42%, #eef1f5 100%);
  padding: 24rpx;
  box-sizing: border-box;
}

.hero-card,
.card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 18rpx 48rpx rgba(28, 39, 54, 0.08);
  margin-bottom: 24rpx;
}

.hero-card {
  background: linear-gradient(140deg, #17212b 0%, #243241 55%, #30445a 100%);
  color: #ffffff;
}

.hero-top,
.section-head,
.distribution-main,
.matrix-row,
.result-grid,
.hero-info-grid {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-top {
  align-items: flex-start;
}

.hero-profile {
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-width: 0;
}

.hero-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.16);
}

.hero-avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
}

.hero-eyebrow {
  display: block;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: rgba(255, 255, 255, 0.68);
  margin-bottom: 14rpx;
}

.hero-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
}

.hero-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.84);
}

.system-pill,
.result-pill {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.system-pill {
  background: rgba(250, 188, 61, 0.18);
  color: #fabc3d;
  border: 2rpx solid rgba(250, 188, 61, 0.42);
}

.hero-tags,
.tag-list,
.reviewer-list,
.decision-grid,
.admin-mode-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.admin-mode-card {
  width: calc(50% - 8rpx);
  border-radius: 24rpx;
  padding: 24rpx;
  box-sizing: border-box;
  background: #f6f8fb;
  border: 2rpx solid #e8ebf0;
}

.admin-mode-card.accent {
  background: linear-gradient(135deg, rgba(31, 122, 236, 0.08), rgba(70, 194, 255, 0.12));
  border-color: rgba(31, 122, 236, 0.24);
}

.admin-mode-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1c2736;
}

.admin-mode-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.65;
  color: #5e6b79;
}

.admin-mode-status {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #1f6ee5;
  font-weight: 700;
}

.mode-action-btn {
  margin-top: 18rpx;
  height: 76rpx;
  border-radius: 999rpx;
  border: none;
  background: linear-gradient(90deg, #1f7aec, #46c2ff);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
}

.mode-action-btn::after {
  border: none;
}

.shared-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx 24rpx;
  margin-top: 20rpx;
  font-size: 22rpx;
  color: #6c7886;
}

.hero-tags {
  margin-top: 28rpx;
}

.hero-tag {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
}

.hero-info-grid,
.result-grid {
  flex-wrap: wrap;
  margin-top: 28rpx;
}

.hero-info-item,
.result-item {
  width: calc(50% - 8rpx);
  background: rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.result-item {
  background: #f7f8fa;
}

.hero-info-item .hero-info-label,
.result-label {
  display: block;
  font-size: 22rpx;
  color: #7a8594;
  margin-bottom: 10rpx;
}

.hero-info-item .hero-info-value,
.result-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
  line-height: 1.5;
}

.result-value {
  color: #1b2430;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1c2736;
}

.section-value,
.section-tip {
  font-size: 24rpx;
  color: #6c7886;
}

.progress-track {
  width: 100%;
  height: 16rpx;
  background: #e7ebf0;
  border-radius: 999rpx;
  overflow: hidden;
  margin-top: 24rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #1f7aec 0%, #46c2ff 100%);
  border-radius: 999rpx;
}

.reviewer-list {
  margin-top: 24rpx;
}

.reviewer-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: calc(50% - 8rpx);
  padding: 20rpx;
  border-radius: 20rpx;
  box-sizing: border-box;
}

.reviewer-item.is-complete {
  background: #eef8f1;
}

.reviewer-item.is-pending {
  background: #f5f6f8;
}

.reviewer-name,
.reviewer-status {
  font-size: 24rpx;
}

.reviewer-status {
  color: #5f6b78;
}

.matrix-table {
  margin-top: 24rpx;
  border: 2rpx solid #e8ebf0;
  border-radius: 24rpx;
  overflow: hidden;
}

.matrix-empty,
.empty-text {
  display: block;
  padding: 24rpx;
  text-align: center;
  font-size: 24rpx;
  color: #7b8795;
}

.matrix-row {
  align-items: stretch;
  gap: 0;
}

.matrix-header {
  background: #f5f7fb;
}

.matrix-cell {
  flex: 1;
  min-width: 0;
  padding: 18rpx 10rpx;
  text-align: center;
  border-right: 2rpx solid #e8ebf0;
  border-bottom: 2rpx solid #e8ebf0;
  font-size: 22rpx;
  color: #384453;
  box-sizing: border-box;
}

.matrix-row:last-child .matrix-cell {
  border-bottom: none;
}

.matrix-cell:last-child {
  border-right: none;
}

.matrix-reviewer {
  flex: 1.6;
}

.reviewer-meta {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
}

.reviewer-role {
  font-size: 24rpx;
  font-weight: 600;
  color: #1c2736;
}

.reviewer-time {
  font-size: 20rpx;
  color: #8a95a3;
}

.grade-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 48rpx;
  height: 48rpx;
  padding: 0 12rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.grade-S,
.chip-s {
  background: rgba(223, 99, 62, 0.16);
  color: #c74725;
}

.grade-A,
.chip-a {
  background: rgba(33, 132, 255, 0.16);
  color: #1f6ee5;
}

.grade-B,
.chip-b {
  background: rgba(88, 175, 80, 0.16);
  color: #348d2a;
}

.grade-C,
.chip-c {
  background: rgba(83, 93, 109, 0.16);
  color: #4d5563;
}

.distribution-row {
  margin-top: 20rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: #f6f8fb;
}

.distribution-row.is-divergent,
.override-alert,
.result-override {
  background: linear-gradient(135deg, rgba(255, 233, 225, 0.92), rgba(255, 245, 239, 0.96));
  border: 2rpx solid rgba(227, 94, 56, 0.26);
}

.distribution-main {
  align-items: flex-start;
}

.distribution-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1c2736;
}

.divergence-badge {
  display: inline-block;
  margin-top: 12rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(227, 94, 56, 0.14);
  color: #c94f2d;
  font-size: 22rpx;
  font-weight: 700;
}

.distribution-counts {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 10rpx;
}

.count-chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.style-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #f2f5f9;
  color: #223040;
  font-size: 24rpx;
}

.style-tag-count {
  color: #6d7784;
}

.attachment-block {
  margin-top: 24rpx;
}

.attachment-title {
  display: block;
  margin-bottom: 18rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #243241;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.photo-item {
  width: calc(33.333% - 11rpx);
}

.photo-image {
  width: 100%;
  height: 180rpx;
  border-radius: 20rpx;
  background: #dfe5eb;
}

.photo-name {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #556171;
}

.video-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.video-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #f4f6fa;
}

.video-play {
  width: 68rpx;
  height: 68rpx;
  line-height: 68rpx;
  text-align: center;
  border-radius: 50%;
  background: #1c2736;
  color: #ffffff;
  font-size: 28rpx;
}

.video-meta {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.video-name {
  font-size: 24rpx;
  color: #1f2a38;
  font-weight: 600;
}

.video-type {
  font-size: 20rpx;
  color: #7b8795;
}

.override-alert {
  border-radius: 24rpx;
  padding: 22rpx;
  margin-top: 24rpx;
}

.override-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #bf4f32;
}

.override-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #8c4a38;
  line-height: 1.5;
}

.decision-grid {
  margin-top: 24rpx;
}

.decision-card {
  width: calc(33.333% - 11rpx);
  padding: 24rpx 18rpx;
  border-radius: 24rpx;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.decision-card.hire {
  background: #edf8ef;
}

.decision-card.hold {
  background: #f6f2e7;
}

.decision-card.reject {
  background: #fbefee;
}

.decision-card.is-active {
  border-color: #1c2736;
  box-shadow: 0 12rpx 28rpx rgba(28, 39, 54, 0.12);
}

.decision-label {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1b2430;
}

.decision-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #617082;
}

.decision-note {
  width: 100%;
  min-height: 180rpx;
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f6f8fb;
  font-size: 26rpx;
  line-height: 1.6;
  color: #1f2a38;
  box-sizing: border-box;
}

.submit-btn {
  margin-top: 24rpx;
  height: 92rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #1c2736 0%, #30445a 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
}

.result-card {
  margin-bottom: 48rpx;
}

.result-hire {
  background: #eaf7ed;
  color: #2c8f45;
}

.result-hold {
  background: #f7f0df;
  color: #9a6a0f;
}

.result-reject {
  background: #fbe9e6;
  color: #c35239;
}

.full {
  width: 100%;
}
