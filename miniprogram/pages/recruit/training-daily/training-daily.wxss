page {
  background: #f5f7fb;
}

.page {
  padding: 24rpx;
}

.hero {
  margin-bottom: 24rpx;
  padding: 32rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #111827, #1d4ed8);
}

.hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 800;
  color: #fff;
}

.hero-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  line-height: 1.7;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 20rpx;
}

.location-card {
  margin-bottom: 18rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  border: 2rpx solid #fde68a;
  background: #fffdf4;
}

.location-card.ok {
  border-color: #86efac;
  background: #f0fdf4;
}

.location-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.location-title {
  font-size: 27rpx;
  font-weight: 700;
  color: #111827;
}

.location-action {
  font-size: 24rpx;
  color: #2563eb;
}

.location-status,
.location-distance {
  display: block;
  font-size: 24rpx;
  line-height: 1.7;
  color: #475569;
}

.form-picker,
.form-textarea {
  width: 100%;
  box-sizing: border-box;
  background: #f8fafc;
  border-radius: 18rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  color: #111827;
}

.form-textarea {
  min-height: 180rpx;
}

.upload-header {
  display: flex;
  justify-content: space-between;
  margin: 8rpx 0 16rpx;
}

.upload-title,
.upload-count {
  font-size: 24rpx;
  color: #64748b;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.photo-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 18rpx;
  overflow: hidden;
  background: #eef2f7;
}

.add-item {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #cbd5e1;
}

.add-text {
  font-size: 28rpx;
  color: #64748b;
}

.photo-image {
  width: 100%;
  height: 100%;
}

.photo-delete {
  position: absolute;
  right: 8rpx;
  top: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: rgba(15, 23, 42, 0.7);
  color: #fff;
  text-align: center;
  line-height: 40rpx;
}

.submit-btn {
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #2563eb, #0f172a);
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
}

.empty-tip {
  font-size: 26rpx;
  color: #94a3b8;
}

.record-card {
  padding: 22rpx 0;
  border-bottom: 2rpx solid #eef2f7;
}

.record-card:last-child {
  border-bottom: none;
}

.record-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.record-date {
  font-size: 26rpx;
  font-weight: 700;
  color: #111827;
}

.record-status {
  font-size: 22rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
}

.status-pending_review {
  background: #fff7ed;
  color: #c2410c;
}

.status-approved {
  background: #ecfdf5;
  color: #047857;
}

.status-rejected {
  background: #fef2f2;
  color: #b91c1c;
}

.record-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #1e293b;
}

.record-summary {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #475569;
}

.review-comment {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7c3aed;
}

.loading {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #64748b;
}
