.page {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(180deg, #f4f7fb 0%, #eef2f8 100%);
  box-sizing: border-box;
}

.hero-card,
.panel {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 18rpx 40rpx rgba(42, 58, 92, 0.08);
}

.hero-card {
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 100%);
  color: #ffffff;
}

.hero-top {
  display: flex;
  gap: 24rpx;
  align-items: center;
}

.avatar {
  width: 132rpx;
  height: 132rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.12);
}

.hero-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.name {
  font-size: 40rpx;
  font-weight: 700;
}

.sub-name,
.meta {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.level-badge {
  min-width: 56rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
}

.level-S {
  background: #facc15;
  color: #111827;
}

.level-A {
  background: #fb7185;
  color: #ffffff;
}

.level-B {
  background: #22c55e;
  color: #ffffff;
}

.level-C {
  background: #94a3b8;
  color: #ffffff;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  font-size: 22rpx;
}

.panel {
  margin-bottom: 24rpx;
}

.panel-title {
  margin-bottom: 20rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.metric-card {
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f8fafc;
}

.metric-label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 22rpx;
  color: #64748b;
}

.metric-value {
  display: block;
  margin-bottom: 8rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.metric-note {
  font-size: 22rpx;
  color: #475569;
}

.info-list,
.practice-list,
.schedule-list,
.timeline-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding-bottom: 18rpx;
  border-bottom: 1rpx solid #e2e8f0;
}

.info-row:last-child {
  padding-bottom: 0;
  border-bottom: none;
}

.info-label {
  font-size: 24rpx;
  color: #64748b;
}

.info-value {
  font-size: 24rpx;
  font-weight: 600;
  color: #0f172a;
  text-align: right;
}

.practice-card {
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f8fafc;
}

.schedule-card {
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f8fafc;
}

.practice-head {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.schedule-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.practice-type,
.practice-score,
.schedule-slot {
  font-size: 24rpx;
  font-weight: 700;
  color: #0f172a;
}

.schedule-status {
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: #dbeafe;
  color: #1d4ed8;
  font-size: 20rpx;
  font-weight: 600;
}

.practice-desc,
.practice-meta,
.practice-comment,
.schedule-main,
.schedule-meta,
.timeline-date,
.timeline-title,
.timeline-desc,
.empty-text,
.loading-text {
  display: block;
  font-size: 24rpx;
  line-height: 1.6;
}

.practice-desc,
.practice-comment,
.schedule-main,
.timeline-title {
  color: #334155;
}

.practice-meta,
.schedule-meta,
.timeline-date,
.timeline-desc,
.empty-text,
.loading-text {
  color: #64748b;
}

.timeline-item {
  display: flex;
  gap: 16rpx;
}

.timeline-axis {
  width: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.timeline-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #2563eb;
  margin-top: 10rpx;
}

.timeline-line {
  width: 4rpx;
  flex: 1;
  background: #cbd5e1;
  margin-top: 8rpx;
}

.timeline-body {
  flex: 1;
  padding-bottom: 20rpx;
}

.timeline-date {
  font-size: 22rpx;
}

.timeline-title {
  font-size: 26rpx;
  font-weight: 700;
  margin-bottom: 4rpx;
}

.loading-state {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f4f7fb;
}
