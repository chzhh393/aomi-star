.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #101C24 0%, #182C38 18%, #F3F4F6 18%, #F3F4F6 100%);
  padding-bottom: 40rpx;
}

.hero {
  padding: 40rpx 28rpx 48rpx;
}

.hero-tag {
  font-size: 20rpx;
  letter-spacing: 3rpx;
  color: rgba(255, 255, 255, 0.72);
}

.hero-title {
  display: block;
  margin-top: 20rpx;
  font-size: 52rpx;
  font-weight: 900;
  color: #FFFFFF;
}

.hero-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.78);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin: -18rpx 24rpx 24rpx;
}

.stat-card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.08);
}

.stat-card.accent {
  background: linear-gradient(135deg, #DCEBFF 0%, #F4F7FF 100%);
}

.stat-value {
  display: block;
  font-size: 42rpx;
  font-weight: 900;
  color: #142019;
}

.stat-label {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6B7280;
}

.tab-row {
  display: flex;
  gap: 16rpx;
  padding: 0 24rpx;
  margin-bottom: 20rpx;
}

.tab-chip {
  padding: 16rpx 26rpx;
  border-radius: 999rpx;
  background: #E5E7EB;
  color: #4B5563;
  font-size: 24rpx;
  font-weight: 700;
}

.tab-chip.active {
  background: #182C38;
  color: #FFFFFF;
}

.empty-state {
  margin: 0 24rpx;
  padding: 56rpx 32rpx;
  background: #FFFFFF;
  border-radius: 28rpx;
  text-align: center;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.06);
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #142019;
}

.empty-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #6B7280;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 24rpx;
}

.candidate-card {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.06);
}

.avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
}

.avatar.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #182C38;
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: 900;
}

.content {
  flex: 1;
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.candidate-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #142019;
}

.arrow {
  font-size: 30rpx;
  color: #9CA3AF;
}

.meta-row {
  display: flex;
  gap: 16rpx;
  margin-top: 10rpx;
  font-size: 22rpx;
}

.meta-label {
  color: #6B7280;
  min-width: 110rpx;
}

.meta-value {
  flex: 1;
  color: #142019;
}
