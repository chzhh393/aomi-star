@import "../../finance/home/home.wxss";

.todo-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.06);
  margin-bottom: 16rpx;
}

.todo-card.frozen {
  border: 2rpx solid rgba(124, 58, 237, 0.18);
  background: linear-gradient(180deg, #FFFFFF 0%, #F7F2FF 100%);
}

.todo-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: flex-start;
}

.todo-title {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  color: #142019;
}

.todo-sub,
.todo-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #6B7280;
}

.todo-badge {
  min-width: 120rpx;
  text-align: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #E7F5EE;
  color: #0F766E;
  font-size: 20rpx;
  font-weight: 800;
}

.todo-badge.danger {
  background: #FFF1F2;
  color: #BE123C;
}

.todo-badge.frozen-badge {
  background: #F3E8FF;
  color: #7C3AED;
}

.scout-card {
  border: 2rpx solid rgba(15, 118, 110, 0.12);
  background: linear-gradient(180deg, #FFFFFF 0%, #F5FBF9 100%);
}

.scout-badge {
  background: #ECFDF5;
  color: #047857;
}

.scout-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 20rpx;
}

.scout-action {
  margin: 0;
  min-width: 148rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.scout-action::after {
  border: none;
}

.scout-action-approve {
  background: #22C55E;
  color: #FFFFFF;
}

.scout-action-reject {
  background: #F3F4F6;
  color: #374151;
}
