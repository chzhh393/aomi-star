.workspace-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background:
    linear-gradient(135deg, rgba(255, 106, 61, 0.12) 0%, transparent 28%),
    radial-gradient(circle at top right, rgba(17, 214, 197, 0.12), transparent 26%),
    linear-gradient(180deg, #09090d 0%, #111116 32%, #f4efe6 32%, #efe7dc 100%);
  padding: 28rpx 24rpx 40rpx;
}

.page-glow {
  position: absolute;
  border-radius: 999rpx;
  filter: blur(20rpx);
  opacity: 0.85;
  pointer-events: none;
}

.page-glow-a {
  width: 260rpx;
  height: 260rpx;
  background: rgba(255, 106, 61, 0.14);
  top: 48rpx;
  left: -64rpx;
}

.page-glow-b {
  width: 300rpx;
  height: 300rpx;
  background: rgba(17, 214, 197, 0.12);
  top: 160rpx;
  right: -110rpx;
}

.workspace-header,
.workspace-card,
.loading-state {
  position: relative;
  z-index: 1;
  background: rgba(249, 244, 236, 0.94);
  box-shadow: 0 22rpx 54rpx rgba(20, 14, 11, 0.14);
  border: 2rpx solid rgba(199, 185, 165, 0.3);
}

.workspace-header {
  border-radius: 38rpx;
  padding: 34rpx 32rpx;
  margin-bottom: 24rpx;
}

.header-kicker {
  display: block;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  color: #7b6e66;
}

.header-title {
  display: block;
  margin-top: 18rpx;
  font-size: 48rpx;
  line-height: 1.18;
  font-weight: 800;
  color: #171214;
}

.header-subtitle {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #695f56;
  line-height: 1.7;
}

.loading-state {
  border-radius: 30rpx;
  padding: 80rpx 32rpx;
  text-align: center;
}

.loading-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #171214;
}

.loading-copy {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #7b6e66;
}

.card-list {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.workspace-card {
  border-radius: 32rpx;
  padding: 28rpx;
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.card-kicker {
  display: block;
  font-size: 20rpx;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  color: #8b7c72;
}

.card-title {
  display: block;
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 800;
  color: #171214;
}

.card-arrow {
  font-size: 30rpx;
  font-weight: 700;
  color: #c46d42;
}

.card-summary {
  display: block;
  margin-top: 20rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #af5f34;
}

.card-detail {
  display: block;
  margin-top: 12rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #61564d;
}

.metric-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.metric-pill {
  flex: 1;
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 2rpx solid rgba(199, 185, 165, 0.24);
}

.metric-value {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: #171214;
}

.metric-label {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #7b6e66;
}

.card-action-btn {
  margin: 22rpx 0 0;
  height: 76rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #151216 0%, #2d241d 62%, #ff6a3d 140%);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
}
