.workspace-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: linear-gradient(180deg, #1a1a1a 0%, #1a1a1a 36%, #f5f5f5 36%, #ffffff 100%);
  padding: 28rpx 24rpx 40rpx;
}

.workspace-header,
.workspace-card,
.loading-state {
  position: relative;
  z-index: 1;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid #e5e5e5;
}

.workspace-header {
  border-radius: 32rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #F8D55D 0%, #FADF7F 100%);
  border: none;
  box-shadow: 0 20rpx 40rpx rgba(248, 213, 93, 0.3);
}

.header-kicker {
  display: block;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  color: rgba(30, 20, 18, 0.72);
}

.header-title {
  display: block;
  margin-top: 18rpx;
  font-size: 46rpx;
  line-height: 1.18;
  font-weight: 700;
  color: #221714;
}

.header-subtitle {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  color: rgba(34, 23, 20, 0.76);
  line-height: 1.7;
}

.loading-state {
  border-radius: 28rpx;
  padding: 80rpx 32rpx;
  text-align: center;
}

.loading-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1b1c22;
}

.loading-copy {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #7d736a;
}

.card-list {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.workspace-card {
  border-radius: 28rpx;
  padding: 24rpx;
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.card-kicker {
  display: block;
  font-size: 20rpx;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  color: #7d736a;
}

.card-title {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #1b1c22;
}

.card-arrow {
  font-size: 30rpx;
  font-weight: 700;
  color: #F8D55D;
}

.card-summary {
  display: block;
  margin-top: 20rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #F8D55D;
}

.card-detail {
  display: block;
  margin-top: 12rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #5d5751;
}

.metric-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.metric-pill {
  flex: 1;
  padding: 20rpx;
  border-radius: 24rpx;
  background: #f9f9f9;
  border: 2rpx solid #e5e5e5;
}

.metric-value {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #1b1c22;
}

.metric-label {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #7d736a;
}

.card-action-btn {
  margin: 22rpx 0 0;
  height: 76rpx;
  border-radius: 999rpx;
  background: #F8D55D;
  color: #1a1a1a;
  font-size: 24rpx;
  font-weight: 700;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
  box-shadow: 0 12rpx 24rpx rgba(248, 213, 93, 0.3);
}
