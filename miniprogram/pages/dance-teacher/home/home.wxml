<view class="workspace-page">
  <view class="page-glow page-glow-a"></view>
  <view class="page-glow page-glow-b"></view>

  <view class="workspace-header">
    <text class="header-kicker">Dance Teacher Workspace</text>
    <text class="header-title">舞蹈老师工作台</text>
    <text class="header-subtitle">按面试管理、教学管理、舞蹈资产管理分区查看概要信息。具体管理内容进入对应页面处理。</text>
  </view>

  <view class="loading-state" wx:if="{{loading}}">
    <text class="loading-title">加载中</text>
    <text class="loading-copy">正在同步舞蹈老师工作台概要信息</text>
  </view>

  <view class="card-list" wx:if="{{!loading}}">
    <view
      class="workspace-card"
      wx:for="{{cards}}"
      wx:key="key"
      bindtap="goToModule"
      data-path="{{item.path}}"
    >
      <view class="card-head">
        <view>
          <text class="card-kicker">{{item.kicker}}</text>
          <text class="card-title">{{item.title}}</text>
        </view>
        <text class="card-arrow">→</text>
      </view>

      <text class="card-summary">{{item.summary}}</text>
      <text class="card-detail">{{item.detail}}</text>

      <view class="metric-row">
        <view class="metric-pill" wx:for="{{item.metrics}}" wx:key="label" wx:for-item="metric">
          <text class="metric-value">{{metric.value}}</text>
          <text class="metric-label">{{metric.label}}</text>
        </view>
      </view>

      <button class="card-action-btn" catchtap="goToModule" data-path="{{item.path}}">{{item.actionText}}</button>
    </view>
  </view>
</view>
