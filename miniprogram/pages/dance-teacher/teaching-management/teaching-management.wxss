page {
  background:
    radial-gradient(circle at top left, rgba(17, 214, 197, 0.16), transparent 30%),
    linear-gradient(180deg, #0c1016 0%, #141c27 24%, #f3ede4 24%, #efe6da 100%);
}

.manage-page {
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
}

.hero-card,
.panel-card,
.loading-state {
  background: rgba(248, 243, 234, 0.96);
  border-radius: 32rpx;
  padding: 28rpx;
  box-shadow: 0 18rpx 48rpx rgba(12, 16, 22, 0.16);
  margin-bottom: 24rpx;
}

.hero-kicker,
.card-tag {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  color: #8b7c72;
}

.hero-title {
  display: block;
  margin-top: 12rpx;
  font-size: 42rpx;
  font-weight: 800;
  color: #171214;
}

.hero-copy,
.info-value,
.attendance-copy,
.candidate-meta,
.empty-copy,
.loading-copy,
.matrix-subtitle {
  display: block;
  font-size: 24rpx;
  line-height: 1.8;
  color: #5f554f;
}

.hero-copy {
  display: block;
  margin-top: 16rpx;
}

.card-head,
.matrix-head,
.candidate-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.card-head-copy {
  flex: 1;
  min-width: 0;
}

.card-title,
.matrix-name,
.candidate-name,
.empty-title,
.loading-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #171214;
}

.card-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #7b6e66;
}

.pill-btn {
  margin: 0;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 106, 61, 0.12);
  color: #af5f34;
  font-size: 22rpx;
  font-weight: 700;
}

.info-block {
  margin-top: 20rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 2rpx solid rgba(199, 185, 165, 0.22);
}

.info-block.emphasis {
  background: linear-gradient(135deg, rgba(255, 106, 61, 0.08), rgba(17, 214, 197, 0.06));
}

.info-block.compact {
  margin-top: 0;
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 16rpx;
}

.info-label,
.attendance-title {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  color: #8d4f2d;
}

.info-value {
  display: block;
  margin-top: 10rpx;
}

.attendance-strip {
  margin-top: 18rpx;
  padding: 24rpx 26rpx;
  border-radius: 24rpx;
  background: rgba(17, 214, 197, 0.08);
  border: 2rpx solid rgba(17, 214, 197, 0.16);
}

.matrix-list,
.candidate-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 18rpx;
}

.matrix-row,
.candidate-card {
  padding: 26rpx;
  border-radius: 24rpx;
  background: #fff;
  border: 2rpx solid rgba(199, 185, 165, 0.36);
}

.matrix-subtitle {
  display: block;
  margin-top: 6rpx;
}

.matrix-sign,
.card-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(17, 214, 197, 0.12);
  color: #0f766e;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.matrix-chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  background: rgba(21, 18, 22, 0.06);
  color: #5b4d45;
}

.matrix-chip.status-not-started {
  background: rgba(110, 110, 110, 0.12);
  color: #5f5f5f;
}

.matrix-chip.status-practice {
  background: rgba(255, 179, 71, 0.18);
  color: #9b6311;
}

.matrix-chip.status-mastered {
  background: rgba(17, 214, 197, 0.16);
  color: #0c8d82;
}

.matrix-chip.status-c {
  background: rgba(255, 106, 61, 0.16);
  color: #b04c24;
}

.candidate-arrow {
  font-size: 28rpx;
  font-weight: 700;
  color: #c46d42;
}

.candidate-meta {
  display: block;
  margin-top: 12rpx;
}

.loading-state,
.empty-state {
  text-align: center;
}

.panel-empty {
  margin-top: 18rpx;
  padding: 42rpx 28rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.62);
  border: 2rpx dashed rgba(199, 185, 165, 0.36);
}

.panel-empty .empty-title {
  margin-bottom: 14rpx;
}

@media (max-width: 420px) {
  .info-grid {
    grid-template-columns: 1fr;
  }
}
