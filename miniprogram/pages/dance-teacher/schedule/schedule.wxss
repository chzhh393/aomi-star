page {
  background:
    radial-gradient(circle at top left, rgba(17, 214, 197, 0.16), transparent 30%),
    linear-gradient(180deg, #0c1016 0%, #141c27 24%, #f3ede4 24%, #efe6da 100%);
}

.schedule-page {
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
}

.hero-card,
.form-card,
.list-card {
  background: rgba(248, 243, 234, 0.96);
  border-radius: 32rpx;
  padding: 28rpx;
  box-shadow: 0 18rpx 48rpx rgba(12, 16, 22, 0.16);
  margin-bottom: 24rpx;
}

.hero-kicker {
  display: block;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  color: #8b7c72;
}

.hero-title {
  display: block;
  margin-top: 12rpx;
  font-size: 42rpx;
  font-weight: 800;
  color: #171214;
}

.hero-copy {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #5f554f;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #171214;
}

.card-tag {
  font-size: 20rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #171214;
  color: #f3ede4;
}

.picker-field,
.text-input,
.text-area {
  width: 100%;
  box-sizing: border-box;
  background: #fff;
  border: 2rpx solid rgba(199, 185, 165, 0.45);
  border-radius: 24rpx;
  padding: 24rpx;
  font-size: 26rpx;
  color: #171214;
  margin-bottom: 18rpx;
}

.hint-field {
  color: #7b6e66;
  font-size: 24rpx;
}

.picker-field {
  min-height: 84rpx;
  display: flex;
  align-items: center;
}

.text-input {
  height: 84rpx;
  padding: 0 24rpx;
  line-height: 84rpx;
}

.time-row {
  display: flex;
  gap: 16rpx;
}

.picker-field.half {
  flex: 1;
}

.text-area {
  min-height: 180rpx;
}

.form-actions,
.slot-actions {
  display: flex;
  gap: 16rpx;
}

.primary-btn,
.ghost-btn,
.danger-btn {
  flex: 1;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.primary-btn {
  background: linear-gradient(135deg, #0f766e 0%, #14b8a6 100%);
  color: #fff;
}

.ghost-btn {
  background: #fff;
  color: #171214;
  border: 2rpx solid rgba(23, 18, 20, 0.12);
}

.danger-btn {
  background: rgba(255, 106, 61, 0.14);
  color: #c2410c;
  border: 2rpx solid rgba(194, 65, 12, 0.14);
}

.small {
  height: 72rpx;
  line-height: 72rpx;
}

.loading-state,
.empty-state {
  padding: 36rpx 0;
  text-align: center;
}

.loading-text,
.empty-copy {
  font-size: 24rpx;
  color: #7b6e66;
}

.empty-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #171214;
  margin-bottom: 10rpx;
}

.slot-card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fff;
  border: 2rpx solid rgba(199, 185, 165, 0.36);
  margin-bottom: 18rpx;
}

.slot-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.slot-time {
  font-size: 28rpx;
  font-weight: 800;
  color: #171214;
}

.slot-status {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
}

.slot-status.is-open {
  background: rgba(17, 214, 197, 0.16);
  color: #0f766e;
}

.slot-status.is-cancelled {
  background: rgba(148, 163, 184, 0.18);
  color: #475569;
}

.slot-meta {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #5f554f;
}

.slot-actions {
  margin-top: 18rpx;
}
