page {
  background:
    radial-gradient(circle at top left, rgba(17, 214, 197, 0.16), transparent 30%),
    linear-gradient(180deg, #0c1016 0%, #141c27 24%, #f3ede4 24%, #efe6da 100%);
}

.manage-page {
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
}

.hero-card,
.summary-card,
.asset-card {
  background: rgba(248, 243, 234, 0.96);
  border-radius: 32rpx;
  padding: 28rpx;
  box-shadow: 0 18rpx 48rpx rgba(12, 16, 22, 0.16);
  margin-bottom: 24rpx;
}

.hero-kicker {
  display: block;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  color: #8b7c72;
}

.hero-title {
  display: block;
  margin-top: 12rpx;
  font-size: 42rpx;
  font-weight: 800;
  color: #171214;
}

.hero-copy,
.asset-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #5f554f;
}

.summary-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  flex-wrap: wrap;
}

.summary-item {
  flex: 1;
  min-width: 180rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: #fff;
  border: 2rpx solid rgba(199, 185, 165, 0.36);
}

.summary-value {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #171214;
}

.summary-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7b6e66;
}

.summary-btn {
  margin: 0;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 106, 61, 0.12);
  color: #af5f34;
  font-size: 22rpx;
  font-weight: 700;
}

.asset-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.asset-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.asset-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #171214;
}

.asset-count {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(17, 214, 197, 0.1);
  color: #0c8d82;
  font-size: 20rpx;
  font-weight: 700;
}

.tag-row,
.version-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.tag,
.version-pill {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.tag {
  background: rgba(255, 179, 71, 0.14);
  color: #9b6311;
}

.version-pill {
  background: rgba(21, 18, 22, 0.08);
  color: #4f4139;
}
