/* pages/external-scout/home/home.wxss */
/* 星探工作台 - 统一配色 */

/* ==================== 主容器 ==================== */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a1a 0%, #1a1a1a 36%, #f5f5f5 36%, #ffffff 100%);
  padding: 28rpx 24rpx 120rpx;
}

/* ==================== 顶部横幅 ==================== */
.header-banner {
  background: linear-gradient(135deg, #F8D55D 0%, #FADF7F 100%);
  padding: 30rpx;
  border-radius: 32rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 20rpx 40rpx rgba(248, 213, 93, 0.3);
}

.banner-slash {
  display: none;
}

.banner-text {
  font-size: 46rpx;
  font-weight: 700;
  color: #221714;
  letter-spacing: 2rpx;
  position: relative;
  z-index: 1;
  display: block;
}

.banner-subtitle {
  font-size: 24rpx;
  color: rgba(34, 23, 20, 0.76);
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 12rpx;
}

/* ==================== 欢迎卡片 ==================== */
.welcome-card {
  background: #ffffff;
  margin: 24rpx 0;
  padding: 24rpx;
  border-radius: 28rpx;
  border: 2rpx solid #e5e5e5;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.welcome-icon {
  font-size: 48rpx;
  flex-shrink: 0;
}

.welcome-content {
  flex: 1;
}

.welcome-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1b1c22;
  margin-bottom: 8rpx;
}

.welcome-desc {
  font-size: 22rpx;
  color: #5d5751;
}

/* ==================== 统计块 ==================== */
.stats-block {
  background: #ffffff;
  margin: 0 0 24rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  border: 2rpx solid #e5e5e5;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.block-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.label-slash {
  width: 6rpx;
  height: 28rpx;
  background: #F8D55D;
  border-radius: 3rpx;
}

.label-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #1b1c22;
  letter-spacing: 2rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.stat-item {
  background: #f9f9f9;
  padding: 24rpx 20rpx;
  text-align: center;
  border-radius: 22rpx;
  border: 2rpx solid #e5e5e5;
}

.stat-item.highlight {
  background: linear-gradient(135deg, #F8D55D 0%, #FADF7F 100%);
  border-color: #F8D55D;
}

.stat-value {
  font-size: 42rpx;
  font-weight: 700;
  color: #F8D55D;
  margin-bottom: 8rpx;
  line-height: 1;
}

.stat-item.highlight .stat-value {
  color: #1a1a1a;
}

.stat-label {
  font-size: 22rpx;
  color: #7d736a;
}

.stat-item.highlight .stat-label {
  color: rgba(26, 26, 26, 0.78);
}

/* ==================== 快捷功能 ==================== */
.actions-block {
  background: #ffffff;
  margin: 0 0 24rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  border: 2rpx solid #e5e5e5;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.actions-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-item {
  background: #f9f9f9;
  border: 2rpx solid #e5e5e5;
  border-radius: 22rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  position: relative;
  overflow: hidden;
  transition: transform 0.2s ease;
}

.action-item:active {
  transform: scale(0.98);
}

.item-accent {
  position: absolute;
  left: 0;
  top: 0;
  width: 6rpx;
  height: 100%;
  background: #F8D55D;
}

.item-icon {
  width: 72rpx;
  height: 72rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 6rpx;
  border: 2rpx solid #e5e5e5;
}

.icon-text {
  font-size: 40rpx;
}

.item-content {
  flex: 1;
}

.item-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1b1c22;
  margin-bottom: 6rpx;
}

.item-desc {
  font-size: 22rpx;
  color: #5d5751;
}

.item-arrow {
  font-size: 30rpx;
  font-weight: 700;
  color: #F8D55D;
  flex-shrink: 0;
}

/* ==================== 最近推荐 ==================== */
.recent-block {
  background: #ffffff;
  margin: 0 0 24rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  border: 2rpx solid #e5e5e5;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.candidate-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.candidate-item {
  background: #f9f9f9;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
  border: 2rpx solid #e5e5e5;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: transform 0.2s ease;
}

.candidate-item:active {
  transform: scale(0.98);
}

.candidate-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #1b1c22;
  flex: 1;
}

.candidate-status {
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
}

.candidate-status.status-pending {
  background: rgba(248, 213, 93, 0.2);
  color: #996B00;
}

.candidate-status.status-interview {
  background: rgba(91, 138, 255, 0.14);
  color: #335ac2;
}

.candidate-status.status-signed,
.candidate-status.status-active {
  background: #dff3dd;
  color: #2f7a2e;
}

/* ==================== 温馨提示 ==================== */
.tips-block {
  margin: 24rpx 0;
  padding: 20rpx 24rpx;
  background: rgba(248, 213, 93, 0.1);
  border-left: 6rpx solid #F8D55D;
  border-radius: 0 22rpx 22rpx 0;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 22rpx;
  color: #5d5751;
  line-height: 1.7;
  flex: 1;
}
