page {
  background: #f5f7fa;
}

.dance-course-page {
  min-height: 100vh;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 220rpx 0;
}

.loading-icon {
  font-size: 92rpx;
  margin-bottom: 24rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #6b7280;
}

.page-content {
  padding: 30rpx;
}

.hero-card,
.info-card,
.empty-state {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(15, 23, 42, 0.06);
}

.hero-card {
  background: linear-gradient(135deg, #0f766e 0%, #14b8a6 100%);
  color: #fff;
}

.hero-kicker {
  display: block;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  opacity: 0.8;
}

.hero-title {
  display: block;
  margin-top: 14rpx;
  font-size: 38rpx;
  font-weight: 800;
}

.hero-copy {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  opacity: 0.9;
}

.card-title {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 18rpx;
  border-bottom: 2rpx solid #f1f5f9;
}

.title-icon {
  font-size: 34rpx;
  margin-right: 14rpx;
}

.title-text {
  font-size: 30rpx;
  font-weight: 800;
  color: #0f172a;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
}

.label {
  width: 180rpx;
  flex-shrink: 0;
  font-size: 26rpx;
  color: #64748b;
}

.value {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  color: #0f172a;
  font-weight: 600;
}

.note-card {
  margin-top: 22rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
}

.note-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #0f172a;
}

.note-text {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #475569;
}

.schedule-day-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.schedule-day-card {
  padding: 24rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
}

.schedule-day-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.schedule-day-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #0f172a;
}

.schedule-day-count {
  font-size: 22rpx;
  color: #0f766e;
  background: rgba(20, 184, 166, 0.12);
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 700;
}

.teacher-group-card {
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 2rpx solid #e5e7eb;
}

.teacher-group-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.teacher-group-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #111827;
}

.teacher-group-count {
  font-size: 22rpx;
  color: #64748b;
}

.dance-course-card {
  margin-top: 16rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  border: 2rpx solid #e5e7eb;
  background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
}

.dance-course-card:first-child {
  margin-top: 0;
}

.dance-course-card.is-active {
  border-color: #0f766e;
  box-shadow: 0 8rpx 22rpx rgba(15, 118, 110, 0.12);
}

.dance-course-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.dance-course-time {
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
}

.dance-course-capacity,
.dance-course-meta {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #475569;
}

.dance-course-btn {
  margin-top: 20rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #0f766e 0%, #14b8a6 100%);
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #0f172a;
}

.empty-copy {
  display: block;
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 1.8;
  color: #64748b;
}
