<!--pages/agent/home/home.wxml-->
<view class="agent-home">
  <!-- 顶部经纪人信息卡片 -->
  <view class="agent-info-card">
    <view class="agent-avatar">
      <text class="avatar-icon">👤</text>
    </view>
    <view class="agent-details">
      <view class="agent-name">{{agentInfo.name || agentInfo.username}}</view>
      <view class="agent-role">经纪人</view>
    </view>
    <view class="logout-btn" bindtap="handleLogout">
      <text class="logout-icon">🚪</text>
    </view>
  </view>

  <!-- 数据统计卡片 -->
  <view class="stats-section">
    <view class="stats-grid">
      <view class="stat-item">
        <text class="stat-value">{{stats.totalCount}}</text>
        <text class="stat-label">分配候选人</text>
      </view>
      <view class="stat-item highlight">
        <text class="stat-value">{{stats.pendingCount}}</text>
        <text class="stat-label">待打分</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{stats.scoredCount}}</text>
        <text class="stat-label">已打分</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{stats.monthCount}}</text>
        <text class="stat-label">本月打分</text>
      </view>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="quick-actions-section">
    <view class="section-title">快捷入口</view>
    <view class="action-grid">
      <view class="action-item" bindtap="goToCandidateList">
        <view class="action-icon-box primary">
          <text class="action-icon">📋</text>
        </view>
        <text class="action-text">候选人列表</text>
        <view class="action-badge" wx:if="{{stats.pendingCount > 0}}">
          {{stats.pendingCount}}
        </view>
      </view>

      <view class="action-item" bindtap="goToMyScores">
        <view class="action-icon-box success">
          <text class="action-icon">⭐</text>
        </view>
        <text class="action-text">评价记录</text>
      </view>
    </view>
  </view>

  <!-- 待打分候选人列表（快速预览） -->
  <view class="pending-section" wx:if="{{pendingCandidates.length > 0}}">
    <view class="section-header">
      <text class="section-title">待打分候选人</text>
      <text class="section-more" bindtap="goToCandidateList">查看全部 →</text>
    </view>

    <view class="candidate-preview-list">
      <view
        wx:for="{{pendingCandidates}}"
        wx:key="_id"
        class="candidate-preview-item"
        bindtap="goToCandidateDetail"
        data-id="{{item._id}}"
      >
        <view class="candidate-name">{{item.basicInfo.name}}</view>
        <view class="candidate-meta">
          <text class="meta-item">{{item.basicInfo.age}}岁</text>
          <text class="meta-divider">·</text>
          <text class="meta-item">{{item.basicInfo.height}}cm</text>
        </view>
        <view class="action-tag">去打分</view>
      </view>
    </view>
  </view>

  <!-- 空状态提示 -->
  <view class="empty-state" wx:if="{{!loading && stats.totalCount === 0}}">
    <text class="empty-icon">📝</text>
    <text class="empty-text">暂无分配的候选人</text>
    <text class="empty-desc">等待管理员为您分配候选人</text>
  </view>

  <!-- 刷新按钮 -->
  <view class="refresh-btn" bindtap="handleRefresh">
    <text class="refresh-icon">🔄</text>
    <text class="refresh-text">刷新数据</text>
  </view>
</view>
