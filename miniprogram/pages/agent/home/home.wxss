page {
  background: linear-gradient(180deg, #1a1a1a 0%, #1a1a1a 36%, #f5f5f5 36%, #ffffff 100%);
}

.agent-home {
  padding: 28rpx 24rpx 110rpx;
}

.hero-card {
  background: linear-gradient(135deg, #F8D55D 0%, #FADF7F 100%);
  border-radius: 32rpx;
  padding: 30rpx;
  box-shadow: 0 20rpx 40rpx rgba(248, 213, 93, 0.3);
  margin-bottom: 24rpx;
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.hero-kicker {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: rgba(30, 20, 18, 0.72);
  margin-bottom: 10rpx;
}

.hero-title {
  font-size: 46rpx;
  font-weight: 700;
  color: #221714;
}

.hero-subtitle {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(34, 23, 20, 0.76);
}

.logout-btn {
  min-width: 108rpx;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 999rpx;
  background: rgba(20, 20, 20, 0.14);
  color: #231815;
  font-size: 24rpx;
  font-weight: 600;
}

.hero-user {
  margin-top: 34rpx;
}

.user-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #211614;
}

.user-role {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(33, 22, 20, 0.74);
}

.hero-metrics {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 28rpx;
}

.duty-grid {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.duty-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 24rpx;
  border: 2rpx solid #e5e5e5;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.duty-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1b1c22;
}

.duty-summary {
  display: block;
  margin-top: 10rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #F8D55D;
}

.duty-detail {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #6d625a;
}

.duty-link {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #F8D55D;
}

.hero-metric {
  background: rgba(255, 255, 255, 0.85);
  border-radius: 24rpx;
  padding: 22rpx 16rpx;
}

.metric-value {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #221714;
}

.metric-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(34, 23, 20, 0.62);
}

.overview-panel,
.section-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid #e5e5e5;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1b1c22;
}

.section-tip {
  max-width: 360rpx;
  font-size: 22rpx;
  line-height: 1.5;
  text-align: right;
  color: #7d736a;
}

.section-tip-inline {
  max-width: none;
  margin-top: -10rpx;
  margin-bottom: 24rpx;
  text-align: left;
}

.section-link {
  font-size: 24rpx;
  font-weight: 600;
  color: #C9A832;
}

.signal-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.signal-box {
  border-radius: 22rpx;
  padding: 28rpx 14rpx;
  text-align: center;
}

.signal-box-green {
  background: #e8f6e5;
}

.signal-box-yellow {
  background: #fff3cf;
}

.signal-box-red {
  background: #ffe0dc;
}

.signal-count {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: #1f1f1f;
}

.signal-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #655e57;
}

.task-list,
.battle-list,
.asset-list,
.candidate-preview-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.task-item,
.battle-item,
.asset-item,
.candidate-preview-item {
  border-radius: 22rpx;
  background: #f9f9f9;
  padding: 22rpx;
}

.task-item {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.task-main {
  flex: 1;
}

.task-header,
.asset-top,
.battle-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.task-name,
.battle-name,
.asset-fan,
.candidate-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1b1c22;
}

.signal-chip,
.asset-tier,
.battle-level,
.candidate-tag {
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.signal-red {
  background: #ffcdc6;
  color: #b73724;
}

.signal-yellow {
  background: #ffe9a8;
  color: #9d6a00;
}

.signal-green {
  background: #dff3dd;
  color: #2f7a2e;
}

.task-meta,
.task-reason,
.task-action,
.battle-time,
.battle-goal,
.battle-skills,
.battle-script,
.asset-anchor,
.asset-preference,
.asset-material,
.asset-followup,
.candidate-meta {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #5d5751;
}

.task-side {
  min-width: 110rpx;
  text-align: right;
}

.task-deadline,
.task-level {
  display: block;
  font-size: 22rpx;
  color: #8a7868;
}

.task-level {
  margin-top: 18rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #1b1c22;
}

.battle-level {
  background: #1b1c22;
  color: #fff6e9;
}

.battle-goal {
  font-weight: 600;
  color: #C9A832;
}

.asset-tier {
  background: rgba(248, 213, 93, 0.3);
  color: #996B00;
}

.schedule-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.schedule-item {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr 1fr;
  gap: 12rpx;
  align-items: center;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #f9f9f9;
  font-size: 24rpx;
  color: #333333;
}

.schedule-name {
  font-weight: 700;
  color: #1b1c22;
}

.schedule-slot {
  text-align: center;
}

.schedule-time {
  text-align: right;
}

.recruit-stats {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.recruit-stat {
  background: #f9f9f9;
  border-radius: 20rpx;
  padding: 24rpx 18rpx;
}

.recruit-stat-warn {
  background: linear-gradient(135deg, #F8D55D 0%, #FADF7F 100%);
}

.recruit-stat-warn .metric-value,
.recruit-stat-warn .metric-label {
  color: #1a1a1a;
}

.quick-actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 20rpx;
  margin-bottom: 20rpx;
}

.quick-action {
  border-radius: 20rpx;
  background: #F8D55D;
  padding: 24rpx 20rpx;
}

.quick-action-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.quick-action-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: rgba(26, 26, 26, 0.7);
}

.candidate-preview-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.candidate-tag {
  background: #F8D55D;
  color: #1a1a1a;
}

.refresh-btn {
  height: 88rpx;
  border-radius: 999rpx;
  background: #F8D55D;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 24rpx rgba(248, 213, 93, 0.3);
}

.refresh-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a1a;
}
