page {
  background: #f7f3eb;
}

.page {
  padding: 24rpx;
}

.hero-card,
.asset-card {
  background: #fffdf8;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(27, 28, 34, 0.06);
}

.hero-card {
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #efe1bf 0%, #fff4d9 100%);
}

.hero-title {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.5;
  color: #3b2b10;
}

.hero-desc {
  margin-top: 12rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: rgba(59, 43, 16, 0.72);
}

.asset-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.asset-top {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.fan-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1b1c22;
}

.anchor-name,
.asset-line {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #5d5751;
}

.fan-tier {
  height: fit-content;
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
  background: #efe1bf;
  color: #7b5718;
  font-size: 22rpx;
  font-weight: 600;
}

.asset-followup {
  color: #d7542f;
  font-weight: 600;
}
