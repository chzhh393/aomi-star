/* pages/scout/home/home.wxss */
.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 40rpx;
}

.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.content {
  padding: 30rpx;
}

/* 等待审核/拒绝状态 */
.pending-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 30rpx;
}

.pending-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 80rpx 40rpx;
  text-align: center;
  width: 100%;
}

.pending-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 30rpx;
}

.pending-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.pending-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.pending-card.rejected .pending-desc {
  color: #f44336;
}

.reapply-link {
  display: inline-block;
  margin-top: 30rpx;
  color: #667eea;
  font-size: 28rpx;
  text-decoration: underline;
}

/* 头部卡片 */
.header-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
}

.welcome {
  display: flex;
  align-items: center;
  gap: 15rpx;
  margin-bottom: 25rpx;
}

.name {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

/* 等级徽章 */
.grade-badge {
  font-size: 22rpx;
  color: #fff;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.grade-rookie {
  background: rgba(255, 255, 255, 0.25);
  border: 1rpx solid rgba(255, 255, 255, 0.4);
}

.grade-special {
  background: rgba(33, 150, 243, 0.4);
  border: 1rpx solid rgba(33, 150, 243, 0.6);
}

.grade-partner {
  background: rgba(255, 193, 7, 0.4);
  border: 1rpx solid rgba(255, 193, 7, 0.6);
}

/* 升级进度 */
.upgrade-section {
  margin-bottom: 20rpx;
}

.upgrade-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 10rpx;
}

.upgrade-label.max-grade {
  color: rgba(255, 215, 0, 0.9);
  font-weight: bold;
}

.progress-bar {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 6rpx;
  transition: width 0.3s;
}

/* 等级权益入口按钮 */
.grade-entry-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.grade-entry-left {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.grade-entry-icon {
  font-size: 40rpx;
}

.grade-entry-text {
  display: flex;
  flex-direction: column;
}

.grade-entry-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.grade-entry-desc {
  font-size: 22rpx;
  color: #999;
}

.grade-entry-arrow {
  font-size: 36rpx;
  color: #999;
  font-weight: bold;
}

/* 分享入口 */
.share-section {
  margin-top: 30rpx;
}

.action-btn {
  height: 72rpx;
  background: #fff;
  color: #667eea;
  border: none;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: bold;
  line-height: 72rpx;
  padding: 0;
  margin: 0;
}

.action-btn.primary {
  background: #fff;
  color: #667eea;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.action-btn::after {
  border: none;
}

/* 统计数据 */
.stats-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 25rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #667eea;
  display: block;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* 筛选器 */
.filter-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.filter-tabs {
  display: flex;
  gap: 15rpx;
  margin-top: 20rpx;
}

.filter-tab {
  flex: 1;
  height: 60rpx;
  background: #f5f7fa;
  border-radius: 10rpx;
  font-size: 26rpx;
  color: #666;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.filter-tab.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-weight: bold;
}

/* 候选人列表 */
.referrals-section {
  margin-bottom: 30rpx;
}

.empty-state {
  background: #fff;
  border-radius: 20rpx;
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 15rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #ccc;
  display: block;
}

.referral-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.referral-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
}

.referral-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.candidate-info {
  flex: 1;
}

.candidate-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.candidate-meta {
  font-size: 24rpx;
  color: #999;
}

.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.status-pending {
  background: #fff3e0;
  color: #ff9800;
}

.status-approved {
  background: #e3f2fd;
  color: #2196f3;
}

.status-interview_scheduled {
  background: #f3e5f5;
  color: #9c27b0;
}

.status-signed {
  background: #e8f5e9;
  color: #4caf50;
}

.status-training {
  background: #e8eaf6;
  color: #5c6bc0;
}

.status-live {
  background: #e0f7fa;
  color: #00897b;
}

.status-probation {
  background: #fff3e0;
  color: #ef6c00;
}

.status-rejected {
  background: #ffebee;
  color: #f44336;
}

/* 生命周期进度条 */
.lifecycle-bar {
  display: flex;
  margin: 20rpx 0 0;
  padding: 16rpx 0 8rpx;
}

.lifecycle-step {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

/* 阶段之间的连接线 */
.lifecycle-step:not(:last-child)::after {
  content: '';
  position: absolute;
  top: 10rpx;
  left: 50%;
  width: 100%;
  height: 3rpx;
  background: #e0e0e0;
  z-index: 0;
}

.lifecycle-step.done:not(:last-child)::after {
  background: #667eea;
}

.lifecycle-step.current:not(:last-child)::after {
  background: linear-gradient(to right, #667eea, #e0e0e0);
}

.lc-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #e0e0e0;
  margin-bottom: 8rpx;
  z-index: 1;
}

.lifecycle-step.done .lc-dot {
  background: #667eea;
}

.lifecycle-step.current .lc-dot {
  background: #667eea;
  box-shadow: 0 0 0 6rpx rgba(102, 126, 234, 0.25);
}

.lc-label {
  font-size: 20rpx;
  color: #bbb;
}

.lifecycle-step.done .lc-label {
  color: #667eea;
}

.lifecycle-step.current .lc-label {
  color: #667eea;
  font-weight: bold;
}

/* 结算提示 */
.settlement-hint {
  font-size: 22rpx;
  color: #667eea;
  background: #eef2ff;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
  margin-top: 16rpx;
}

.settlement-hint.probation {
  color: #ef6c00;
  background: #fff3e0;
}

.referral-details {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 20rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.detail-row:last-child {
  margin-bottom: 0;
}

.detail-label {
  font-size: 26rpx;
  color: #999;
}

.detail-value {
  font-size: 26rpx;
  color: #333;
}

/* 刷新按钮 */
.refresh-section {
  text-align: center;
}

.refresh-btn {
  width: 100%;
  height: 80rpx;
  background: #fff;
  border: 2rpx solid #e0e0e0;
  border-radius: 40rpx;
  color: #666;
  font-size: 28rpx;
  line-height: 80rpx;
  padding: 0;
  margin: 0;
}

.refresh-btn::after {
  border: none;
}
