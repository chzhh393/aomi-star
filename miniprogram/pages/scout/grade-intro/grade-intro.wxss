/* pages/scout/grade-intro/grade-intro.wxss */
.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 顶部 Banner */
.hero {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx 50rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.hero-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 等级列表 */
.grade-list {
  padding: 30rpx;
}

/* 等级卡片 */
.grade-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.grade-card.current {
  box-shadow: 0 8rpx 30rpx rgba(102, 126, 234, 0.25);
}

/* 等级头部 */
.grade-header {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  gap: 20rpx;
}

.grade-header.rookie {
  background: linear-gradient(135deg, #e8eaf6 0%, #f3e5f5 100%);
}

.grade-header.special {
  background: linear-gradient(135deg, #e3f2fd 0%, #e8eaf6 100%);
}

.grade-header.partner {
  background: linear-gradient(135deg, #fff8e1 0%, #fff3e0 100%);
}

.grade-icon {
  font-size: 48rpx;
  flex-shrink: 0;
}

.grade-title-area {
  flex: 1;
}

.grade-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.grade-condition {
  font-size: 24rpx;
  color: #888;
}

.current-badge {
  font-size: 22rpx;
  color: #667eea;
  background: rgba(102, 126, 234, 0.12);
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-weight: bold;
  flex-shrink: 0;
}

/* 等级内容 */
.grade-body {
  padding: 24rpx 30rpx 30rpx;
}

.benefit-title {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.benefit-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.benefit-item {
  text-align: center;
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 16rpx 8rpx;
}

.benefit-item.ss {
  background: #fffde7;
  border: 1rpx solid #fff9c4;
}

.benefit-level {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.benefit-amount {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.benefit-amount.highlight {
  color: #2196f3;
}

.benefit-amount.top {
  color: #ff9800;
}

.benefit-extra {
  font-size: 20rpx;
  color: #ff9800;
  margin-top: 6rpx;
  font-weight: 500;
}

/* 升级箭头 */
.upgrade-arrow {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 10rpx;
}

.arrow-line {
  flex: 1;
  height: 2rpx;
  background: linear-gradient(to right, transparent, #ddd, transparent);
}

.arrow-text {
  font-size: 24rpx;
  color: #999;
  white-space: nowrap;
  font-weight: 500;
}

/* 通用 section */
.section {
  margin: 0 30rpx 30rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.section-icon {
  font-size: 36rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

/* 结算时间线 */
.timeline {
  padding-left: 10rpx;
}

.timeline-item {
  display: flex;
  gap: 20rpx;
  padding-bottom: 30rpx;
  position: relative;
}

.timeline-item:not(:last-child)::after {
  content: '';
  position: absolute;
  left: 12rpx;
  top: 32rpx;
  bottom: 0;
  width: 2rpx;
  background: #e0e0e0;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #e0e0e0;
  flex-shrink: 0;
  margin-top: 6rpx;
  z-index: 1;
}

.timeline-dot.active {
  background: #667eea;
  box-shadow: 0 0 0 6rpx rgba(102, 126, 234, 0.2);
}

.timeline-content {
  flex: 1;
}

.timeline-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.timeline-desc {
  font-size: 24rpx;
  color: #888;
  line-height: 1.6;
}

.timeline-desc .amount {
  color: #667eea;
  font-weight: bold;
}

/* 定级表格 */
.level-table {
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #f0f0f0;
}

.level-row {
  display: flex;
  border-bottom: 1rpx solid #f0f0f0;
}

.level-row:last-child {
  border-bottom: none;
}

.level-row.header {
  background: #f9fafb;
}

.level-row.header .level-cell {
  font-weight: bold;
  color: #666;
  font-size: 24rpx;
}

.level-row.ss {
  background: #fffde7;
}

.level-cell {
  flex: 1;
  padding: 18rpx 16rpx;
  font-size: 24rpx;
  color: #555;
  text-align: center;
}

.level-cell.label {
  font-weight: bold;
  color: #333;
  flex: 0.6;
}

/* 说明区域 */
.note-section {
  margin-bottom: 60rpx;
}

.note-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.note-item {
  font-size: 24rpx;
  color: #888;
  line-height: 1.8;
  padding-left: 20rpx;
  position: relative;
}

.note-item::before {
  content: '·';
  position: absolute;
  left: 0;
  color: #999;
  font-weight: bold;
}
