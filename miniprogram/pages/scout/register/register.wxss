/* pages/scout/register/register.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.form-content {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
}

.invite-plan-card {
  margin-bottom: 30rpx;
  padding: 28rpx 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #fff7ed 0%, #fffbeb 100%);
  border: 1rpx solid #fed7aa;
}

.invite-plan-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #9a3412;
  margin-bottom: 18rpx;
}

.invite-plan-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.invite-plan-row:last-of-type {
  margin-bottom: 0;
}

.invite-plan-label {
  font-size: 26rpx;
  color: #7c2d12;
}

.invite-plan-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #c2410c;
}

.invite-plan-tip {
  margin-top: 18rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #9a3412;
}

.form-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.form-field {
  margin-bottom: 30rpx;
}

.field-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.field-input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.field-textarea {
  width: 100%;
  height: 200rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.submit-section {
  margin-top: 60rpx;
}

.submit-btn {
  width: 100%;
  height: 90rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 45rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
}

.submit-btn:active {
  opacity: 0.8;
}

.submit-btn[disabled] {
  opacity: 0.6;
}

/* 状态卡片 */
.status-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 80rpx 40rpx;
  text-align: center;
}

.status-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 30rpx;
}

.status-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.status-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.status-card.rejected .status-desc {
  color: #f44336;
}

.reapply-btn {
  margin-top: 40rpx;
  width: 300rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 40rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
}
