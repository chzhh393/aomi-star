/* pages/scout/register/register.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.form-content {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
}

.form-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.form-field {
  margin-bottom: 30rpx;
}

.field-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.field-input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.submit-section {
  margin-top: 60rpx;
}

.submit-btn {
  width: 100%;
  height: 90rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 45rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  line-height: 90rpx;
}

.submit-btn:active {
  opacity: 0.8;
}

.submit-btn[disabled] {
  opacity: 0.6;
}

/* 邀请码输入区域 */
.invite-code-input {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.invite-input {
  flex: 1;
}

.verify-btn {
  flex-shrink: 0;
  width: 130rpx;
  height: 60rpx;
  line-height: 60rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 10rpx;
  font-size: 24rpx;
  padding: 0;
  border: none;
}

.verify-btn::after {
  border: none;
}

.verify-btn[disabled] {
  background: #e0e0e0;
  color: #999;
}

/* 上级星探信息 */
.parent-info {
  display: flex;
  align-items: center;
  margin-top: 15rpx;
  padding: 15rpx 20rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
  border-radius: 10rpx;
  border-left: 4rpx solid #667eea;
}

.parent-info-icon {
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  background: #4caf50;
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: bold;
  margin-right: 15rpx;
  flex-shrink: 0;
}

.parent-info-text {
  font-size: 26rpx;
  color: #667eea;
  font-weight: 500;
}
