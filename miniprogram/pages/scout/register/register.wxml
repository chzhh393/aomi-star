<!--pages/scout/register/register.wxml-->
<view class="container">
  <!-- 顶部标题 -->
  <view class="header">
    <view class="title">申请成为星探</view>
    <view class="subtitle">推荐优秀主播，赚取推荐奖励</view>
  </view>

  <!-- 等待审核状态 -->
  <view wx:if="{{applicationStatus === 'pending'}}" class="status-card pending">
    <view class="status-icon">⏳</view>
    <view class="status-title">申请已提交</view>
    <view class="status-desc">您的申请正在审核中，请耐心等待</view>
  </view>

  <!-- 被拒绝状态 -->
  <view wx:elif="{{applicationStatus === 'rejected'}}" class="status-card rejected">
    <view class="status-icon">❌</view>
    <view class="status-title">申请未通过</view>
    <view class="status-desc" wx:if="{{existingScout.application.reviewNote}}">
      原因：{{existingScout.application.reviewNote}}
    </view>
    <button class="reapply-btn" bindtap="reApply">重新申请</button>
  </view>

  <!-- 申请表单 -->
  <view wx:else class="form-content">
    <view wx:if="{{inviterScout}}" class="status-card pending">
      <view class="status-title">{{invitePlan ? invitePlan.title : '二级星探招募入口'}}</view>
      <view class="status-desc">上级星探：{{inviterScout.scoutName || '未命名星探'}}</view>
      <view class="status-desc">绑定后，你推荐的主播业绩会同步计入上级星探团队成果。</view>
    </view>

    <view wx:if="{{invitePlan}}" class="invite-plan-card">
      <view class="invite-plan-title">收益分配方案</view>
      <view class="invite-plan-row">
        <text class="invite-plan-label">签约奖</text>
        <text class="invite-plan-value">{{invitePlan.signingAward}} 元</text>
      </view>
      <view class="invite-plan-row">
        <text class="invite-plan-label">S档定级奖</text>
        <text class="invite-plan-value">{{invitePlan.levelAwards.S}} 元</text>
      </view>
      <view class="invite-plan-row">
        <text class="invite-plan-label">A档定级奖</text>
        <text class="invite-plan-value">{{invitePlan.levelAwards.A}} 元</text>
      </view>
      <view class="invite-plan-row">
        <text class="invite-plan-label">B档定级奖</text>
        <text class="invite-plan-value">{{invitePlan.levelAwards.B}} 元</text>
      </view>
      <view class="invite-plan-tip">提交申请后，系统会按该邀请方案记录你的收益分配配置。</view>
    </view>

    <view class="form-section">
      <view class="section-title">基本信息</view>

      <view class="form-field">
        <text class="field-label">真实姓名 *</text>
        <input
          class="field-input"
          placeholder="请输入真实姓名"
          value="{{formData.name}}"
          data-field="name"
          bindinput="onInput"
        />
      </view>

      <view class="form-field">
        <text class="field-label">手机号 *</text>
        <input
          class="field-input"
          type="number"
          placeholder="请输入手机号"
          maxlength="11"
          value="{{formData.phone}}"
          data-field="phone"
          bindinput="onInput"
        />
      </view>

      <view class="form-field">
        <text class="field-label">身份证号 *</text>
        <input
          class="field-input"
          placeholder="请输入18位身份证号"
          maxlength="18"
          value="{{formData.idCard}}"
          data-field="idCard"
          bindinput="onInput"
        />
      </view>

      <view class="form-field">
        <text class="field-label">微信号</text>
        <input
          class="field-input"
          placeholder="请输入微信号（选填）"
          value="{{formData.wechat}}"
          data-field="wechat"
          bindinput="onInput"
        />
      </view>

      <view class="form-field">
        <text class="field-label">申请理由 *</text>
        <textarea
          class="field-textarea"
          placeholder="请简述您为什么想成为星探，有哪些资源优势"
          maxlength="500"
          value="{{formData.reason}}"
          data-field="reason"
          bindinput="onInput"
        />
        <view class="char-count">{{formData.reason.length || 0}}/500</view>
      </view>
    </view>

    <!-- 提交按钮 -->
    <view class="submit-section">
      <button
        class="submit-btn"
        bindtap="submitApply"
        disabled="{{submitting}}"
      >
        {{submitting ? '提交中...' : '提交申请'}}
      </button>
    </view>
  </view>
</view>
