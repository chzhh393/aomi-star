.detail-page {
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
  background:
    radial-gradient(circle at 12% 0%, rgba(224, 122, 44, 0.16), transparent 24%),
    radial-gradient(circle at 92% 10%, rgba(45, 162, 153, 0.14), transparent 24%),
    linear-gradient(180deg, #f3ede2 0%, #efe7da 100%);
}

.hero-card,
.loading-card,
.task-card {
  border-radius: 30rpx;
  border: 2rpx solid rgba(101, 82, 57, 0.12);
  box-shadow: 0 18rpx 44rpx rgba(50, 37, 20, 0.08);
}

.hero-card {
  padding: 30rpx;
  margin-bottom: 22rpx;
  background: linear-gradient(135deg, #1a1714 0%, #2a231c 100%);
}

.hero-kicker,
.hero-title,
.hero-copy,
.task-title,
.task-value,
.task-detail {
  display: block;
}

.hero-kicker {
  color: rgba(255, 255, 255, 0.64);
  font-size: 22rpx;
  letter-spacing: 4rpx;
}

.hero-title {
  margin-top: 12rpx;
  font-size: 40rpx;
  font-weight: 900;
  color: #fff8ef;
}

.hero-copy {
  margin-top: 14rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: rgba(255, 247, 235, 0.82);
}

.anchor-mini-btn {
  margin: 0 0 22rpx;
  padding: 0 24rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: #df7b2c;
  color: #fff;
  font-size: 24rpx;
  font-weight: 800;
  border: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.loading-card {
  padding: 40rpx 30rpx;
  background: rgba(255, 251, 245, 0.94);
  text-align: center;
  color: #7a6653;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.task-card {
  padding: 22rpx;
  background: linear-gradient(180deg, #fffaf3 0%, #fff 100%);
}

.task-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #241c16;
}

.task-value {
  margin-top: 12rpx;
  color: #c65b16;
  font-size: 22rpx;
  font-weight: 800;
}

.task-detail {
  margin-top: 10rpx;
  color: #7a6653;
  font-size: 22rpx;
  line-height: 1.7;
}

.photo-strip {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 22rpx;
}

.photo-card {
  width: calc(50% - 9rpx);
  height: 220rpx;
  border-radius: 22rpx;
  overflow: hidden;
  background: #e7ded0;
}

.refined-photo {
  width: 100%;
  height: 100%;
}
