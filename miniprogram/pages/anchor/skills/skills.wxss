.detail-page {
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
  background:
    radial-gradient(circle at 12% 0%, rgba(224, 122, 44, 0.16), transparent 24%),
    radial-gradient(circle at 92% 10%, rgba(45, 162, 153, 0.14), transparent 24%),
    linear-gradient(180deg, #f3ede2 0%, #efe7da 100%);
}

.hero-card,
.loading-card,
.skill-card {
  border-radius: 30rpx;
  border: 2rpx solid rgba(101, 82, 57, 0.12);
  box-shadow: 0 18rpx 44rpx rgba(50, 37, 20, 0.08);
}

.hero-card {
  padding: 30rpx;
  margin-bottom: 22rpx;
  background: linear-gradient(135deg, #1a1714 0%, #2a231c 100%);
}

.hero-kicker,
.hero-title,
.hero-copy {
  display: block;
}

.hero-kicker {
  color: rgba(255, 255, 255, 0.64);
  font-size: 22rpx;
  letter-spacing: 4rpx;
}

.hero-title {
  margin-top: 12rpx;
  font-size: 40rpx;
  font-weight: 900;
  color: #fff8ef;
}

.hero-copy {
  margin-top: 14rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: rgba(255, 247, 235, 0.82);
}

.hero-badge {
  display: inline-block;
  margin-top: 18rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 210, 123, 0.18);
  color: #ffd27b;
  font-size: 20rpx;
  font-weight: 800;
}

.loading-card {
  padding: 40rpx 30rpx;
  background: rgba(255, 251, 245, 0.94);
  text-align: center;
  color: #7a6653;
}

.skill-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.skill-card {
  padding: 22rpx;
  background: rgba(255, 251, 245, 0.94);
}

.skill-head,
.skill-meta {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.skill-name {
  font-size: 28rpx;
  font-weight: 800;
  color: #241c16;
}

.skill-badge {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(191, 146, 72, 0.12);
  color: #9a5e16;
  font-size: 20rpx;
  font-weight: 800;
}

.skill-badge.is-mastered {
  background: rgba(43, 150, 128, 0.14);
  color: #117264;
}

.skill-bar {
  margin-top: 16rpx;
  height: 20rpx;
  border-radius: 999rpx;
  background: #efe6d9;
  overflow: hidden;
}

.skill-bar-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #df7b2c 0%, #2aa99b 100%);
}

.skill-meta {
  margin-top: 12rpx;
}

.skill-progress,
.skill-status {
  font-size: 22rpx;
}

.skill-progress {
  color: #c65b16;
  font-weight: 800;
}

.skill-status {
  color: #7a6653;
}
