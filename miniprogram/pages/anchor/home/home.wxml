<view class="anchor-page" wx:if="{{!loading && candidate}}">
  <view class="anchor-hero">
    <view class="hero-topline">
      <text class="anchor-kicker">GROWTH CENTER</text>
      <text class="hero-badge">{{masteredCount}} / 4 已点亮</text>
    </view>
    <text class="anchor-title">{{heroTitle}}</text>
    <text class="anchor-subtitle">主播工作台</text>
    <text class="anchor-copy">{{heroDesc}}</text>
  </view>

  <view class="entry-list">
    <view
      wx:for="{{anchorCards}}"
      wx:key="key"
      class="entry-card"
      bindtap="goToCard"
      data-path="{{item.path}}"
    >
      <text class="entry-title">{{item.title}}</text>
      <text class="entry-summary">{{item.summary}}</text>
      <text class="entry-detail">{{item.detail}}</text>
      <text class="entry-link">点击进入</text>
    </view>
  </view>

  <view class="anchor-card support-card">
    <view class="section-head">
      <view>
        <text class="anchor-card-title">经纪人支持</text>
        <text class="section-tip">需要调整训练安排或确认直播节奏时，直接联系你的经纪人。</text>
      </view>
      <button class="anchor-mini-btn ghost" bindtap="contactAgent">联系经纪人</button>
    </view>
    <view class="anchor-info-row">
      <text class="anchor-label">经纪人</text>
      <text class="anchor-value">{{agentSummary.name}}</text>
    </view>
    <view class="anchor-info-row">
      <text class="anchor-label">联系电话</text>
      <text class="anchor-value">{{agentSummary.phone}}</text>
    </view>
  </view>

  <button class="anchor-primary-btn" bindtap="goToStatusPage">查看完整状态流程</button>
</view>

<view class="anchor-loading" wx:if="{{loading}}">
  <text>加载中...</text>
</view>
