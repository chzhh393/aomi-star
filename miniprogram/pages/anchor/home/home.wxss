page {
  background: #f4efe6;
}

.anchor-page {
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
  background:
    radial-gradient(circle at 12% 0%, rgba(224, 122, 44, 0.16), transparent 24%),
    radial-gradient(circle at 92% 10%, rgba(45, 162, 153, 0.14), transparent 24%),
    linear-gradient(180deg, #f3ede2 0%, #efe7da 100%);
}

.anchor-hero,
.entry-card,
.anchor-card,
.anchor-loading {
  border-radius: 32rpx;
  border: 2rpx solid rgba(101, 82, 57, 0.12);
  box-shadow: 0 18rpx 44rpx rgba(50, 37, 20, 0.08);
}

.anchor-hero {
  padding: 34rpx 30rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #1a1714 0%, #2a231c 50%, #3a2f24 100%);
}

.hero-topline,
.section-head,
.anchor-info-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.hero-topline,
.section-head {
  align-items: flex-start;
}

.anchor-kicker,
.anchor-title,
.anchor-subtitle,
.anchor-copy,
.anchor-card-title,
.section-tip,
.entry-title,
.entry-summary,
.entry-detail,
.entry-link {
  display: block;
}

.anchor-kicker {
  color: rgba(255, 255, 255, 0.64);
  font-size: 22rpx;
  letter-spacing: 4rpx;
}

.hero-badge {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 210, 123, 0.18);
  color: #ffd27b;
  font-size: 20rpx;
  font-weight: 800;
}

.anchor-title {
  margin-top: 14rpx;
  font-size: 46rpx;
  line-height: 1.15;
  font-weight: 900;
  color: #fff8ef;
}

.anchor-subtitle {
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #ffd7a8;
}

.anchor-copy {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: rgba(255, 247, 235, 0.8);
}

.entry-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.entry-card {
  padding: 24rpx;
  background: rgba(255, 251, 245, 0.94);
}

.entry-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #1f1812;
}

.entry-summary {
  margin-top: 10rpx;
  font-size: 32rpx;
  font-weight: 900;
  color: #c65b16;
}

.entry-detail {
  margin-top: 10rpx;
  color: #7a6653;
  font-size: 22rpx;
  line-height: 1.7;
}

.entry-link {
  margin-top: 12rpx;
  color: #117264;
  font-size: 22rpx;
  font-weight: 800;
}

.anchor-card {
  background: rgba(255, 251, 245, 0.94);
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.anchor-card-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #1f1812;
}

.section-tip {
  margin-top: 8rpx;
  color: #7a6653;
  font-size: 22rpx;
  line-height: 1.7;
}

.support-card .anchor-info-row {
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1px solid rgba(140, 115, 84, 0.12);
}

.support-card .anchor-info-row:last-child {
  border-bottom: none;
}

.anchor-label {
  color: #7a6653;
  font-size: 22rpx;
}

.anchor-value {
  flex: 1;
  text-align: right;
  color: #241c16;
  font-size: 22rpx;
  font-weight: 700;
}

.anchor-mini-btn,
.anchor-primary-btn {
  border: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.anchor-mini-btn {
  margin: 0;
  padding: 0 24rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: #efe6d9;
  color: #7f4d20;
  font-size: 24rpx;
  font-weight: 800;
}

.anchor-mini-btn.ghost {
  background: #efe6d9;
  color: #7f4d20;
}

.anchor-primary-btn {
  height: 92rpx;
  border-radius: 46rpx;
  background: linear-gradient(135deg, #df7b2c 0%, #1f7d70 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 900;
}

.anchor-loading {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7a6653;
  background: #f4efe6;
}
