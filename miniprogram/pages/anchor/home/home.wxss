page {
  background: linear-gradient(180deg, #1a1a1a 0%, #1a1a1a 36%, #f5f5f5 36%, #ffffff 100%);
}

.anchor-page {
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
  background: transparent;
}

.anchor-hero,
.entry-card,
.anchor-card,
.anchor-loading {
  border-radius: 28rpx;
  border: 2rpx solid #e5e5e5;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.anchor-hero {
  padding: 30rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #F8D55D 0%, #FADF7F 100%);
  border: none;
  box-shadow: 0 20rpx 40rpx rgba(248, 213, 93, 0.3);
}

.hero-topline,
.section-head,
.anchor-info-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.hero-topline,
.section-head {
  align-items: flex-start;
}

.anchor-kicker,
.anchor-title,
.anchor-subtitle,
.anchor-copy,
.anchor-card-title,
.section-tip,
.entry-title,
.entry-summary,
.entry-detail,
.entry-link {
  display: block;
}

.anchor-kicker {
  color: rgba(30, 20, 18, 0.72);
  font-size: 20rpx;
  letter-spacing: 4rpx;
}

.hero-badge {
  flex-shrink: 0;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.85);
  color: #1a1a1a;
  font-size: 20rpx;
  font-weight: 700;
}

.anchor-title {
  margin-top: 18rpx;
  font-size: 46rpx;
  line-height: 1.18;
  font-weight: 700;
  color: #221714;
}

.anchor-subtitle {
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #221714;
}

.anchor-copy {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(34, 23, 20, 0.76);
}

.entry-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.entry-card {
  padding: 24rpx;
  background: #ffffff;
}

.entry-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1b1c22;
}

.entry-summary {
  margin-top: 10rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #F8D55D;
}

.entry-detail {
  margin-top: 10rpx;
  color: #5d5751;
  font-size: 22rpx;
  line-height: 1.7;
}

.entry-link {
  margin-top: 12rpx;
  color: #F8D55D;
  font-size: 22rpx;
  font-weight: 700;
}

.anchor-card {
  background: #ffffff;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.anchor-card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1b1c22;
}

.section-tip {
  margin-top: 8rpx;
  color: #5d5751;
  font-size: 22rpx;
  line-height: 1.7;
}

.support-card .anchor-info-row {
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.support-card .anchor-info-row:last-child {
  border-bottom: none;
}

.anchor-label {
  color: #7d736a;
  font-size: 22rpx;
}

.anchor-value {
  flex: 1;
  text-align: right;
  color: #1b1c22;
  font-size: 22rpx;
  font-weight: 700;
}

.anchor-mini-btn,
.anchor-primary-btn {
  border: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.anchor-mini-btn {
  margin: 0;
  padding: 0 24rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: #f9f9f9;
  color: #1b1c22;
  font-size: 24rpx;
  font-weight: 700;
  border: 2rpx solid #e5e5e5;
}

.anchor-mini-btn.ghost {
  background: #f9f9f9;
  color: #1b1c22;
}

.anchor-primary-btn {
  height: 88rpx;
  border-radius: 22rpx;
  background: #F8D55D;
  color: #1a1a1a;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 24rpx rgba(248, 213, 93, 0.3);
}

.anchor-loading {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7d736a;
  background: #ffffff;
}
