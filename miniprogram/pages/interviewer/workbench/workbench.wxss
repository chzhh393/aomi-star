.workspace-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background:
    linear-gradient(135deg, rgba(255, 106, 61, 0.12) 0%, transparent 28%),
    radial-gradient(circle at top right, rgba(17, 214, 197, 0.12), transparent 26%),
    linear-gradient(180deg, #09090d 0%, #111116 32%, #f4efe6 32%, #efe7dc 100%);
  padding: 28rpx 24rpx 40rpx;
}

.page-glow {
  position: absolute;
  border-radius: 999rpx;
  filter: blur(20rpx);
  opacity: 0.85;
  pointer-events: none;
}

.page-glow-a {
  width: 260rpx;
  height: 260rpx;
  background: rgba(255, 106, 61, 0.14);
  top: 48rpx;
  left: -64rpx;
}

.page-glow-b {
  width: 300rpx;
  height: 300rpx;
  background: rgba(17, 214, 197, 0.12);
  top: 160rpx;
  right: -110rpx;
}

.workspace-header,
.tabs-card,
.candidate-card,
.makeup-summary-card,
.makeup-group-card,
.makeup-task-card,
.empty-state,
.loading-state {
  position: relative;
  z-index: 1;
  background: rgba(249, 244, 236, 0.92);
  box-shadow: 0 22rpx 54rpx rgba(20, 14, 11, 0.14);
  border: 2rpx solid rgba(199, 185, 165, 0.3);
}

.workspace-header {
  border-radius: 38rpx;
  padding: 34rpx 32rpx 34rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.workspace-header::before {
  content: '';
  position: absolute;
  top: 22rpx;
  left: 32rpx;
  width: 144rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #ff6a3d 0%, #11d6c5 100%);
}

.header-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 12rpx;
}

.header-tag {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 18rpx;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 999rpx;
  box-shadow: 0 12rpx 28rpx rgba(31, 41, 55, 0.18);
}

.header-kicker {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  color: #7b6e66;
}

.header-title {
  display: block;
  margin-top: 24rpx;
  font-size: 48rpx;
  line-height: 1.18;
  font-weight: 800;
  color: #171214;
}

.header-subtitle {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #695f56;
  line-height: 1.7;
}

.tabs-card {
  display: flex;
  gap: 14rpx;
  margin-bottom: 24rpx;
  padding: 10rpx;
  border-radius: 28rpx;
}

.makeup-section {
  position: relative;
  z-index: 1;
  margin-bottom: 24rpx;
}

.makeup-summary-grid,
.makeup-group-stack,
.makeup-task-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.makeup-summary-card,
.makeup-group-card,
.makeup-task-card {
  border-radius: 30rpx;
  padding: 24rpx;
  background: rgba(249, 244, 236, 0.92);
}

.makeup-summary-title,
.makeup-group-title {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  color: #171214;
}

.makeup-summary-value,
.makeup-group-summary {
  display: block;
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 800;
  color: #c44c7d;
}

.makeup-summary-desc,
.makeup-group-desc,
.makeup-summary-highlight,
.makeup-focus-text {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #6d625a;
}

.makeup-summary-highlight {
  color: #a53f69;
  font-weight: 700;
}

.makeup-group-head {
  margin-bottom: 16rpx;
}

.makeup-focus-text {
  margin-top: 14rpx;
  color: #7d495f;
}

.tab-item {
  flex: 1;
  min-height: 122rpx;
  padding: 22rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  border-radius: 22rpx;
}

.tab-item.active {
  background: linear-gradient(135deg, #151216 0%, #2d241d 62%, #ff6a3d 140%);
  box-shadow: 0 14rpx 30rpx rgba(21, 18, 22, 0.22);
}

.tab-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #433730;
}

.tab-count {
  font-size: 34rpx;
  line-height: 1;
  font-weight: 800;
  color: #9f7a50;
}

.tab-item.active .tab-text,
.tab-item.active .tab-count {
  color: #ffffff;
}

.candidate-list {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.assigned-section {
  position: relative;
  z-index: 1;
  margin-top: 28rpx;
}

.assigned-section-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.assigned-section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #171214;
}

.assigned-section-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.65;
  color: #6d625a;
}

.assigned-section-count {
  flex-shrink: 0;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 179, 71, 0.12);
  border: 2rpx solid rgba(255, 179, 71, 0.28);
  color: #ab6d15;
  font-size: 22rpx;
  font-weight: 700;
}

.interview-manage-card {
  position: relative;
  z-index: 1;
  margin-bottom: 24rpx;
  padding: 28rpx 30rpx;
  border-radius: 30rpx;
  background: rgba(249, 244, 236, 0.92);
  box-shadow: 0 22rpx 54rpx rgba(20, 14, 11, 0.14);
  border: 2rpx solid rgba(199, 185, 165, 0.3);
}

.interview-manage-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #171214;
}

.interview-manage-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.65;
  color: #6d625a;
}

.interview-manage-metrics {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 18rpx;
}

.interview-manage-metric {
  padding: 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.68);
  border: 2rpx solid rgba(199, 185, 165, 0.26);
}

.interview-manage-value {
  display: block;
  font-size: 36rpx;
  line-height: 1;
  font-weight: 800;
  color: #171214;
}

.interview-manage-label {
  display: block;
  margin-top: 10rpx;
  font-size: 20rpx;
  color: #7b6e66;
}

.candidate-card {
  padding: 22rpx;
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  border-radius: 30rpx;
}

.candidate-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  min-width: 0;
}

.candidate-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #1a171c, #3b312a);
  flex-shrink: 0;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 800;
  color: #f4efe6;
}

.candidate-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.candidate-name {
  min-width: 0;
  font-size: 32rpx;
  font-weight: 800;
  color: #171214;
}

.candidate-arrow {
  flex-shrink: 0;
  font-size: 28rpx;
  font-weight: 700;
  color: #c46d42;
}

.candidate-info-grid {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 14rpx 16rpx;
  border-radius: 22rpx;
  background: rgba(255, 250, 244, 0.88);
  border: 2rpx solid rgba(216, 203, 187, 0.46);
}

.info-row {
  display: grid;
  grid-template-columns: 112rpx minmax(0, 1fr);
  align-items: start;
  column-gap: 14rpx;
}

.info-label {
  font-size: 22rpx;
  line-height: 1.55;
  color: #8b7c72;
  letter-spacing: 1rpx;
}

.info-value {
  min-width: 0;
  font-size: 23rpx;
  line-height: 1.55;
  color: #2a221d;
  font-weight: 600;
  word-break: break-all;
}

.assigned-action-row {
  margin-top: 10rpx;
}

.assigned-action-text {
  display: block;
  font-size: 21rpx;
  line-height: 1.7;
  color: #7f736b;
}

.assigned-action-text.is-highlight {
  color: #b86d1d;
  font-weight: 700;
}

.assigned-button-row {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  flex-wrap: nowrap;
}

.assigned-action-btn {
  flex: 1;
  min-width: 0;
  max-width: 300rpx;
  margin: 0;
  padding: 0 28rpx;
  height: 76rpx;
  border-radius: 18rpx;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.assigned-action-btn::after {
  border: none;
}

.assigned-action-btn.primary {
  background: linear-gradient(135deg, #f59e0b, #ea580c);
  color: #fff;
}

.assigned-action-btn.secondary {
  background: #f8fafc;
  color: #334155;
  border: 2rpx solid #dbe3ef;
}

.empty-state,
.loading-state {
  border-radius: 32rpx;
  padding: 80rpx 32rpx;
  text-align: center;
}

.empty-mark {
  display: block;
  font-size: 52rpx;
  line-height: 1;
  font-weight: 800;
  color: #ccb9a4;
}

.empty-title,
.loading-title {
  display: block;
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: #171214;
}

.empty-desc,
.loading-copy {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #7b6e66;
  line-height: 1.6;
}
