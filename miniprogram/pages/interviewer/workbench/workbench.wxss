.workspace-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: linear-gradient(180deg, #1a1a1a 0%, #1a1a1a 36%, #f5f5f5 36%, #ffffff 100%);
  padding: 28rpx 24rpx 40rpx;
}

.workspace-header,
.tabs-card,
.candidate-card,
.makeup-summary-card,
.makeup-group-card,
.makeup-task-card,
.empty-state,
.loading-state {
  position: relative;
  z-index: 1;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid #e5e5e5;
}

.workspace-header {
  border-radius: 32rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #F8D55D 0%, #FADF7F 100%);
  border: none;
  box-shadow: 0 20rpx 40rpx rgba(248, 213, 93, 0.3);
}

.workspace-header::before {
  display: none;
}

.header-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.header-tag {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 18rpx;
  color: #1a1a1a;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.85);
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.08);
}

.header-kicker {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  color: rgba(30, 20, 18, 0.72);
}

.header-title {
  display: block;
  margin-top: 18rpx;
  font-size: 46rpx;
  line-height: 1.18;
  font-weight: 700;
  color: #221714;
}

.header-subtitle {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  color: rgba(34, 23, 20, 0.76);
  line-height: 1.7;
}

.tabs-card {
  display: flex;
  gap: 14rpx;
  margin-bottom: 24rpx;
  padding: 10rpx;
  border-radius: 28rpx;
}

.makeup-section {
  position: relative;
  z-index: 1;
  margin-bottom: 24rpx;
}

.makeup-summary-grid,
.makeup-group-stack,
.makeup-task-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.makeup-summary-card,
.makeup-group-card,
.makeup-task-card {
  border-radius: 28rpx;
  padding: 24rpx;
  background: #ffffff;
}

.makeup-summary-title,
.makeup-group-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1b1c22;
}

.makeup-summary-value,
.makeup-group-summary {
  display: block;
  margin-top: 10rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #F8D55D;
}

.makeup-summary-desc,
.makeup-group-desc,
.makeup-summary-highlight,
.makeup-focus-text {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #5d5751;
}

.makeup-summary-highlight {
  color: #996B00;
  font-weight: 700;
}

.makeup-group-head {
  margin-bottom: 16rpx;
}

.makeup-focus-text {
  margin-top: 14rpx;
  color: #7d736a;
}

.tab-item {
  flex: 1;
  min-height: 122rpx;
  padding: 22rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  border-radius: 22rpx;
}

.tab-item.active {
  background: linear-gradient(135deg, #F8D55D 0%, #FADF7F 100%);
  box-shadow: 0 8rpx 20rpx rgba(248, 213, 93, 0.3);
}

.tab-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #5d5751;
}

.tab-count {
  font-size: 34rpx;
  line-height: 1;
  font-weight: 700;
  color: #7d736a;
}

.tab-item.active .tab-text,
.tab-item.active .tab-count {
  color: #1a1a1a;
}

.candidate-list {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.assigned-section {
  position: relative;
  z-index: 1;
  margin-top: 24rpx;
}

.assigned-section-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.assigned-section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1b1c22;
}

.assigned-section-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.65;
  color: #5d5751;
}

.assigned-section-count {
  flex-shrink: 0;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(248, 213, 93, 0.15);
  border: 2rpx solid rgba(248, 213, 93, 0.3);
  color: #996B00;
  font-size: 22rpx;
  font-weight: 700;
}

.interview-manage-card {
  position: relative;
  z-index: 1;
  margin-bottom: 24rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid #e5e5e5;
}

.interview-manage-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1b1c22;
}

.interview-manage-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.65;
  color: #5d5751;
}

.interview-manage-metrics {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 18rpx;
}

.interview-manage-metric {
  padding: 20rpx;
  border-radius: 22rpx;
  background: #f9f9f9;
  border: 2rpx solid #e5e5e5;
}

.interview-manage-value {
  display: block;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 700;
  color: #1b1c22;
}

.interview-manage-label {
  display: block;
  margin-top: 10rpx;
  font-size: 20rpx;
  color: #7d736a;
}

.candidate-card {
  padding: 22rpx;
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  border-radius: 28rpx;
}

.candidate-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  min-width: 0;
}

.candidate-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 28rpx;
  background: #f9f9f9;
  border: 2rpx solid #e5e5e5;
  flex-shrink: 0;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #1b1c22;
}

.candidate-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.candidate-name {
  min-width: 0;
  font-size: 28rpx;
  font-weight: 700;
  color: #1b1c22;
}

.candidate-arrow {
  flex-shrink: 0;
  font-size: 28rpx;
  font-weight: 700;
  color: #F8D55D;
}

.candidate-info-grid {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 14rpx 16rpx;
  border-radius: 22rpx;
  background: #f9f9f9;
  border: 2rpx solid #e5e5e5;
}

.info-row {
  display: grid;
  grid-template-columns: 112rpx minmax(0, 1fr);
  align-items: start;
  column-gap: 14rpx;
}

.info-label {
  font-size: 22rpx;
  line-height: 1.55;
  color: #7d736a;
  letter-spacing: 1rpx;
}

.info-value {
  min-width: 0;
  font-size: 23rpx;
  line-height: 1.55;
  color: #1b1c22;
  font-weight: 600;
  word-break: break-all;
}

.assigned-action-row {
  margin-top: 10rpx;
}

.assigned-action-text {
  display: block;
  font-size: 21rpx;
  line-height: 1.7;
  color: #7d736a;
}

.assigned-action-text.is-highlight {
  color: #996B00;
  font-weight: 700;
}

.assigned-button-row {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  flex-wrap: nowrap;
}

.assigned-action-btn {
  flex: 1;
  min-width: 0;
  max-width: 300rpx;
  margin: 0;
  padding: 0 28rpx;
  height: 76rpx;
  border-radius: 18rpx;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.assigned-action-btn::after {
  border: none;
}

.assigned-action-btn.primary {
  background: #F8D55D;
  color: #1a1a1a;
  box-shadow: 0 8rpx 20rpx rgba(248, 213, 93, 0.3);
}

.assigned-action-btn.secondary {
  background: #f9f9f9;
  color: #1b1c22;
  border: 2rpx solid #e5e5e5;
}

.empty-state,
.loading-state {
  border-radius: 28rpx;
  padding: 80rpx 32rpx;
  text-align: center;
}

.empty-mark {
  display: block;
  font-size: 52rpx;
  line-height: 1;
  font-weight: 700;
  color: #e5e5e5;
}

.empty-title,
.loading-title {
  display: block;
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #1b1c22;
}

.empty-desc,
.loading-copy {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #7d736a;
  line-height: 1.6;
}
