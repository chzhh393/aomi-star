.container {
  min-height: 100vh;
  padding: 48rpx 26rpx 120rpx;
  background: linear-gradient(180deg, #1a1a1a 0%, #1a1a1a 36%, #f5f5f5 36%, #ffffff 100%);
}

.hero {
  position: relative;
  padding: 32rpx 8rpx 54rpx;
}

.hero-kicker {
  display: block;
  font-size: 20rpx;
  letter-spacing: 8rpx;
  color: rgba(255, 255, 255, 0.42);
}

.hero-title {
  display: block;
  margin-top: 18rpx;
  font-size: 68rpx;
  font-weight: 800;
  line-height: 1.02;
  color: #f8f2e8;
  letter-spacing: 4rpx;
  text-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.24);
}

.hero-subtitle {
  display: block;
  margin-top: 22rpx;
  font-size: 25rpx;
  line-height: 1.85;
  color: rgba(244, 239, 230, 0.76);
}

.panel {
  position: relative;
  background: #ffffff;
  border-radius: 42rpx;
  padding: 38rpx 30rpx 48rpx;
  border: 2rpx solid #e5e5e5;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.panel::before {
  content: '';
  position: absolute;
  top: 22rpx;
  left: 30rpx;
  width: 148rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #F8D55D 0%, #FADF7F 100%);
}

.role-selector {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 34rpx;
}

.selector-head {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.selector-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #171214;
}

.selector-desc {
  font-size: 23rpx;
  line-height: 1.75;
  color: #666666;
}

.role-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.role-chip {
  min-width: 140rpx;
  padding: 18rpx 22rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 2rpx solid #e0e0e0;
  color: #333333;
  font-size: 25rpx;
  font-weight: 700;
  text-align: center;
  box-sizing: border-box;
}

.role-chip.is-active {
  background: #F8D55D;
  border-color: #F8D55D;
  color: #1a1a1a;
  box-shadow: 0 8rpx 20rpx rgba(248, 213, 93, 0.3);
}

.selected-role-banner {
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(248, 213, 93, 0.15);
  border: 2rpx solid rgba(248, 213, 93, 0.4);
  color: #996B00;
  font-size: 25rpx;
  font-weight: 700;
}

.form-section {
  display: flex;
  flex-direction: column;
  gap: 36rpx;
}

.intro-card {
  padding: 30rpx 28rpx 28rpx;
  border-radius: 30rpx;
  background: #f9f9f9;
  border: 2rpx solid #e5e5e5;
}

.register-intro {
  background: rgba(248, 213, 93, 0.08);
  border-color: rgba(248, 213, 93, 0.2);
}

.session-card {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 40rpx 30rpx 32rpx;
  border-radius: 32rpx;
  background: #ffffff;
  border: 3rpx solid #F8D55D;
  box-shadow: 0 8rpx 24rpx rgba(248, 213, 93, 0.12);
}

.intro-title {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: #171214;
}

.session-title {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: #1a1a1a;
}

.intro-desc {
  display: block;
  font-size: 25rpx;
  line-height: 1.82;
  color: #666666;
}

.session-desc {
  display: block;
  font-size: 25rpx;
  line-height: 1.82;
  color: #666666;
}

.switch-account-link {
  align-self: center;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #C9A832;
  font-weight: 600;
}


.field-row {
  display: flex;
  gap: 24rpx;
}

.field-item {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.field-half {
  flex: 1;
  min-width: 0;
}

.field-label {
  font-size: 25rpx;
  color: #333333;
  font-weight: 700;
  padding-left: 6rpx;
}

.field-input,
.picker-input {
  width: 100%;
  min-height: 92rpx;
  padding: 0 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 2rpx solid #e0e0e0;
  color: #1a1a1a;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.picker-static {
  color: #151214;
  font-weight: 700;
}

.primary-btn {
  margin-top: 12rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  border-radius: 999rpx;
  background: #F8D55D;
  color: #1a1a1a;
  font-size: 30rpx;
  font-weight: 800;
  text-align: center;
  letter-spacing: 2rpx;
  box-shadow: 0 12rpx 28rpx rgba(248, 213, 93, 0.3);
}

.primary-btn[disabled] {
  opacity: 0.7;
}

.primary-btn::after {
  border: none;
}

.register-entry {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 26rpx;
}

.register-text {
  color: #666666;
}

.register-link {
  color: #C9A832;
  font-weight: 700;
  font-size: 28rpx;
  line-height: 1.6;
  padding: 8rpx 10rpx;
}

.form-tip {
  font-size: 23rpx;
  line-height: 1.85;
  color: #888888;
  text-align: center;
  padding: 12rpx 18rpx 0;
}

.empty-form-state {
  padding: 40rpx 24rpx;
  border-radius: 28rpx;
  background: #f9f9f9;
  border: 2rpx dashed #d0d0d0;
  text-align: center;
}

.empty-form-text {
  font-size: 24rpx;
  line-height: 1.7;
  color: #888888;
}
