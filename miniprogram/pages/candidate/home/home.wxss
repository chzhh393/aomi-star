/* pages/candidate/home/home.wxss */
/* 候选人工作台 - 统一配色 */

/* ==================== 主容器 ==================== */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a1a 0%, #1a1a1a 36%, #f5f5f5 36%, #ffffff 100%);
  padding: 28rpx 24rpx 120rpx;
}

/* ==================== 顶部横幅 ==================== */
.header-banner {
  background: linear-gradient(135deg, #F8D55D 0%, #FADF7F 100%);
  padding: 30rpx;
  border-radius: 32rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 20rpx 40rpx rgba(248, 213, 93, 0.3);
}

.banner-slash {
  display: none;
}

.banner-text {
  font-size: 46rpx;
  font-weight: 700;
  color: #221714;
  letter-spacing: 2rpx;
  position: relative;
  z-index: 1;
  display: block;
}

.banner-subtitle {
  font-size: 24rpx;
  color: rgba(34, 23, 20, 0.76);
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 12rpx;
}

/* ==================== 状态卡片 ==================== */
.status-card {
  background: #ffffff;
  margin: 24rpx 0;
  padding: 40rpx 32rpx;
  border-radius: 28rpx;
  border: 2rpx solid #e5e5e5;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  text-align: center;
  position: relative;
}

.status-icon-wrapper {
  margin-bottom: 20rpx;
}

.status-icon {
  font-size: 80rpx;
}

.status-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1b1c22;
  margin-bottom: 16rpx;
}

.status-desc {
  font-size: 24rpx;
  color: #5d5751;
  line-height: 1.7;
}

/* ==================== 进度块 ==================== */
.progress-block {
  background: #ffffff;
  margin: 0 0 24rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  border: 2rpx solid #e5e5e5;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.block-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.label-slash {
  width: 6rpx;
  height: 28rpx;
  background: #F8D55D;
  border-radius: 3rpx;
}

.label-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #1b1c22;
  letter-spacing: 2rpx;
}

.progress-steps {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.step-icon-box {
  width: 72rpx;
  height: 72rpx;
  background: #f9f9f9;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  border: 2rpx solid #e5e5e5;
}

.step-item.active .step-icon-box {
  background: linear-gradient(135deg, #F8D55D 0%, #FADF7F 100%);
  border-color: #F8D55D;
}

.step-icon {
  font-size: 36rpx;
}

.step-label {
  font-size: 22rpx;
  color: #7d736a;
  font-weight: 600;
}

.step-item.active .step-label {
  color: #996B00;
  font-weight: 700;
}

.step-line {
  flex: 1;
  height: 4rpx;
  background: #e5e5e5;
  position: relative;
  margin: 0 16rpx;
}

.step-line-fill {
  height: 100%;
  width: 0;
  background: #F8D55D;
  transition: width 0.5s ease;
}

.step-line-fill.active {
  width: 100%;
}

/* ==================== 审核信息块 ==================== */
.review-block {
  background: #ffffff;
  margin: 0 0 24rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  border: 2rpx solid #e5e5e5;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.review-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.review-item:last-child {
  border-bottom: none;
}

.review-label {
  font-size: 24rpx;
  color: #7d736a;
  font-weight: 600;
}

.review-value {
  font-size: 24rpx;
  color: #1b1c22;
  font-weight: 700;
  max-width: 60%;
  text-align: right;
}

/* ==================== 操作按钮 ==================== */
.actions-block {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-btn {
  width: 100%;
  height: 88rpx;
  border: none;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background: #F8D55D;
  color: #1a1a1a;
  box-shadow: 0 12rpx 24rpx rgba(248, 213, 93, 0.3);
}

.btn-secondary {
  background: #f9f9f9;
  color: #1b1c22;
  border: 2rpx solid #e5e5e5;
}

.btn-ghost {
  background: transparent;
  color: #1b1c22;
  border: 2rpx solid #e5e5e5;
}

.btn-primary:active {
  opacity: 0.9;
}

.btn-secondary:active,
.btn-ghost:active {
  opacity: 0.8;
}

.action-row {
  display: flex;
  gap: 16rpx;
}

.action-row .action-btn {
  flex: 1;
}

.btn-text {
  font-size: 28rpx;
  font-weight: 700;
}

/* ==================== 温馨提示 ==================== */
.tips-block {
  margin: 24rpx 0;
  padding: 20rpx 24rpx;
  background: rgba(248, 213, 93, 0.1);
  border-left: 6rpx solid #F8D55D;
  border-radius: 0 22rpx 22rpx 0;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 22rpx;
  color: #5d5751;
  line-height: 1.7;
  flex: 1;
}
