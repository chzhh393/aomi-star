<!--pages/index/index.wxml-->
<!--游客首页 - 双入口设计-->
<view class="container">

  <!-- 品牌展示区域 -->
  <view class="brand-section">
    <view class="brand-slash"></view>
    <text class="brand-title">LIVE STREAM</text>
    <text class="brand-subtitle">开启你的直播事业</text>
  </view>

  <!-- 双入口卡片区域 -->
  <view class="entry-section">

    <!-- 主播招募入口 -->
    <view class="entry-card recruit-card" bindtap="goToRecruit">
      <view class="card-icon">🎯</view>
      <view class="card-content">
        <text class="card-title">主播招募</text>
        <text class="card-desc">加入我们，成为未来之星</text>
      </view>
      <view class="card-button">
        <text class="button-text">立即报名</text>
        <text class="button-arrow">→</text>
      </view>
      <view class="card-accent"></view>
    </view>

    <!-- 星探入口 -->
    <view class="entry-card scout-card" bindtap="goToScout">
      <view class="card-icon">🔍</view>
      <view class="card-content">
        <text class="card-title">成为星探</text>
        <text class="card-desc">推荐主播赚奖励</text>
      </view>
      <view class="card-button">
        <text class="button-text">立即注册</text>
        <text class="button-arrow">→</text>
      </view>
      <view class="card-accent"></view>
    </view>

    <!-- 员工入口 - 小卡片 -->
    <view class="entry-card employee-card employee-card-small" bindtap="goToEmployee">
      <view class="small-card-left">
        <view class="card-icon-small">💼</view>
        <view class="card-content-small">
          <text class="card-title-small">员工入口</text>
          <text class="card-desc-small">员工工作台</text>
        </view>
      </view>
      <view class="card-button-small">
        <text class="button-text-small">进入工作台</text>
        <text class="button-arrow-small">→</text>
      </view>
    </view>

  </view>

  <!-- 底部标语 -->
  <view class="footer-motto">
    <text class="motto-text">KEEP STREAMING. STAY WINNING.</text>
  </view>

</view>
