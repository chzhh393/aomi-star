<view class="hr-home">
  <view class="hero-panel">
    <view class="hero-copy">
      <text class="hero-kicker">HR OPS CENTER</text>
      <text class="hero-title">HR 工作台</text>
      <text class="hero-desc">围绕招募看板、面试数字化、入职与档案、人才回访库统一推进候选人转化。</text>
    </view>
    <view class="hero-user">
      <text class="user-role">HR</text>
      <text class="user-name">{{userInfo.profile.name || userInfo.username}}</text>
    </view>
  </view>

  <view class="hero-stats">
    <view class="stat-card accent">
      <text class="stat-value">{{heroStats.total}}</text>
      <text class="stat-label">简历总量</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{heroStats.pendingScreen}}</text>
      <text class="stat-label">待初筛</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{heroStats.interviewing}}</text>
      <text class="stat-label">已约面试</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{heroStats.pendingOnboard}}</text>
      <text class="stat-label">待入职</text>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">四大模块</text>
      <text class="section-link" bindtap="onRefresh">刷新</text>
    </view>
    <view class="module-grid">
      <view
        wx:for="{{modules}}"
        wx:key="key"
        class="module-card"
        bindtap="onOpenModule"
        data-url="{{item.url}}"
      >
        <text class="module-title">{{item.title}}</text>
        <text class="module-desc">{{item.desc}}</text>
        <text class="module-metric">{{item.metric}}</text>
        <text class="module-highlight">{{item.highlight}}</text>
        <view class="module-cta">进入模块</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">当前优先处理</text>
      <text class="section-subtitle">先推进待初筛和待入职候选人</text>
    </view>
    <view wx:if="{{priorities.length === 0}}" class="empty-card">
      <text class="empty-title">当前没有紧急任务</text>
      <text class="empty-desc">招募看板和入职档案都比较平稳，可以转入回访池维护。</text>
    </view>
    <view wx:else class="priority-list">
      <view wx:for="{{priorities}}" wx:key="id" class="priority-card">
        <view class="priority-copy">
          <text class="priority-tag">{{item.tag}}</text>
          <text class="priority-name">{{item.name}}</text>
          <text class="priority-subtitle">{{item.subtitle}}</text>
        </view>
        <button class="priority-btn" bindtap="onHandlePriority" data-id="{{item.id}}" data-action="{{item.action}}">
          {{item.actionText}}
        </button>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">人才回访预览</text>
      <text class="section-link" bindtap="onOpenFollowUpModule">查看全部</text>
    </view>
    <view wx:if="{{followUpPreview.length === 0}}" class="empty-card">
      <text class="empty-title">回访库当前为空</text>
      <text class="empty-desc">暂无 B/C 级待跟进候选人，30 天自动提醒会在这里聚合展示。</text>
    </view>
    <view wx:else class="followup-list">
      <view wx:for="{{followUpPreview}}" wx:key="id" class="followup-card">
        <view class="followup-top">
          <text class="followup-name">{{item.basicInfo.name}}</text>
          <text class="followup-grade">评级 {{item.followUpGrade}}</text>
        </view>
        <text class="followup-meta">提醒日期：{{item.reminderDate || '待生成'}} · {{item.source || '未知来源'}}</text>
        <text class="followup-state">{{item.reminderDue ? '该候选人近期可能有变动，建议回访' : '已进入回访节奏，等待提醒节点'}}</text>
      </view>
    </view>
  </view>
</view>
