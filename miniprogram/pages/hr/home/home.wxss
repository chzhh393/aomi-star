.hr-home {
  min-height: 100vh;
  padding: 28rpx 24rpx 110rpx;
  background: linear-gradient(180deg, #1a1a1a 0%, #1a1a1a 36%, #f5f5f5 36%, #ffffff 100%);
}

.hero-panel {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 30rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #F8D55D 0%, #FADF7F 100%);
  color: #221714;
  box-shadow: 0 20rpx 40rpx rgba(248, 213, 93, 0.3);
}

.hero-copy {
  flex: 1;
}

.hero-kicker {
  display: block;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: rgba(30, 20, 18, 0.72);
}

.hero-title {
  display: block;
  margin-top: 14rpx;
  font-size: 46rpx;
  font-weight: 700;
  color: #221714;
}

.hero-desc {
  display: block;
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(34, 23, 20, 0.76);
}

.hero-user {
  min-width: 168rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.85);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.user-role {
  font-size: 20rpx;
  color: rgba(34, 23, 20, 0.62);
  letter-spacing: 4rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #221714;
}

.hero-stats {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.stat-card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 2rpx solid #e5e5e5;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.stat-card.accent {
  background: linear-gradient(135deg, #F8D55D 0%, #FADF7F 100%);
  border: none;
  color: #1a1a1a;
  box-shadow: 0 12rpx 24rpx rgba(248, 213, 93, 0.3);
}

.stat-value {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #1b1c22;
}

.stat-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(34, 23, 20, 0.62);
}

.stat-card.accent .stat-value {
  color: #1a1a1a;
}

.stat-card.accent .stat-label {
  color: rgba(26, 26, 26, 0.78);
}

.section {
  margin-top: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1b1c22;
}

.section-subtitle,
.section-link {
  font-size: 24rpx;
  color: #F8D55D;
  font-weight: 600;
}

.module-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.module-card {
  min-height: 252rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: #ffffff;
  border: 2rpx solid #e5e5e5;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.module-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1b1c22;
}

.module-desc {
  display: block;
  min-height: 104rpx;
  margin-top: 14rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #5d5751;
}

.module-metric {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #F8D55D;
}

.module-highlight {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7d736a;
}

.module-cta {
  display: inline-flex;
  margin-top: 18rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #F8D55D;
  color: #1a1a1a;
  font-size: 22rpx;
  font-weight: 600;
}

.empty-card {
  padding: 34rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 2rpx solid #e5e5e5;
}

.empty-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1b1c22;
}

.empty-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7d736a;
}

.priority-list,
.followup-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.priority-card,
.followup-card {
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 2rpx solid #e5e5e5;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.priority-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.priority-copy {
  flex: 1;
}

.priority-tag,
.followup-grade {
  display: inline-flex;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(248, 213, 93, 0.2);
  color: #996B00;
  font-size: 20rpx;
  font-weight: 600;
}

.priority-name,
.followup-name {
  display: block;
  margin-top: 14rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #1b1c22;
}

.priority-subtitle,
.followup-meta,
.followup-state {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #5d5751;
}

.priority-btn {
  margin: 0;
  padding: 0 24rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  background: #F8D55D;
  color: #1a1a1a;
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(248, 213, 93, 0.3);
}

.priority-btn::after {
  border: none;
}

.followup-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
