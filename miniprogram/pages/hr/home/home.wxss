.hr-home {
  min-height: 100vh;
  padding: 28rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 212, 163, 0.45), transparent 26%),
    linear-gradient(180deg, #18212b 0%, #223141 34%, #f2ebe2 34%, #f7f2ea 100%);
}

.hero-panel {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 36rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #21303f, #10181f);
  color: #fff9ef;
  box-shadow: 0 20rpx 50rpx rgba(17, 23, 30, 0.24);
}

.hero-copy {
  flex: 1;
}

.hero-kicker {
  display: block;
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: #f6b26b;
}

.hero-title {
  display: block;
  margin-top: 14rpx;
  font-size: 52rpx;
  font-weight: 700;
}

.hero-desc {
  display: block;
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(255, 249, 239, 0.78);
}

.hero-user {
  min-width: 168rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.08);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.user-role {
  font-size: 20rpx;
  color: #f6b26b;
  letter-spacing: 4rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
}

.hero-stats {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 24rpx;
}

.stat-card {
  padding: 28rpx;
  border-radius: 24rpx;
  background: #fffdf8;
  box-shadow: 0 12rpx 30rpx rgba(50, 44, 36, 0.08);
}

.stat-card.accent {
  background: linear-gradient(135deg, #f6b26b, #e88d52);
  color: #1f1710;
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
}

.stat-label {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #6b625b;
}

.stat-card.accent .stat-label {
  color: rgba(31, 23, 16, 0.78);
}

.section {
  margin-top: 28rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a232d;
}

.section-subtitle,
.section-link {
  font-size: 24rpx;
  color: #8d6f52;
}

.module-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.module-card {
  min-height: 252rpx;
  padding: 28rpx;
  border-radius: 26rpx;
  background: linear-gradient(180deg, #fffdf7, #f4ece3);
  box-shadow: 0 16rpx 36rpx rgba(40, 32, 26, 0.08);
}

.module-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #202830;
}

.module-desc {
  display: block;
  min-height: 104rpx;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6f665d;
}

.module-metric {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #9a4f23;
}

.module-highlight {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7a7268;
}

.module-cta {
  display: inline-flex;
  margin-top: 18rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #1c2b37;
  color: #fff6ea;
  font-size: 22rpx;
}

.empty-card {
  padding: 34rpx;
  border-radius: 24rpx;
  background: #fffaf2;
}

.empty-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #26303a;
}

.empty-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #756b63;
}

.priority-list,
.followup-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.priority-card,
.followup-card {
  padding: 26rpx 28rpx;
  border-radius: 24rpx;
  background: #fffdf8;
  box-shadow: 0 12rpx 30rpx rgba(50, 44, 36, 0.08);
}

.priority-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.priority-copy {
  flex: 1;
}

.priority-tag,
.followup-grade {
  display: inline-flex;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f5e5d3;
  color: #8d4c20;
  font-size: 20rpx;
}

.priority-name,
.followup-name {
  display: block;
  margin-top: 14rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2831;
}

.priority-subtitle,
.followup-meta,
.followup-state {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #756b63;
}

.priority-btn {
  margin: 0;
  padding: 0 24rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  background: #20303f;
  color: #fff8ee;
  font-size: 24rpx;
}

.priority-btn::after {
  border: none;
}

.followup-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
