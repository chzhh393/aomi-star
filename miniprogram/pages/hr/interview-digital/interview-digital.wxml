<view class="page">
  <view class="hero">
    <text class="hero-title">面试数字化</text>
    <text class="hero-desc">从发起面试、生成通知到进入 HR 评分入口，全部集中在这里完成。</text>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">一键发起面试</text>
      <text class="section-subtitle">待初筛 / 待邀约候选人</text>
    </view>
    <view wx:if="{{arrangeCandidates.length === 0}}" class="empty-card">
      <text class="empty-text">当前没有需要发起面试的候选人。</text>
    </view>
    <view wx:else class="card-list">
      <view wx:for="{{arrangeCandidates}}" wx:key="recordId" class="card">
        <view class="candidate-row">
          <image wx:if="{{item.avatar}}" class="candidate-avatar" src="{{item.avatar}}" mode="aspectFill"></image>
          <view wx:else class="candidate-avatar avatar-placeholder">{{item.displayInitial}}</view>
          <view class="candidate-content">
            <text class="card-title">{{item.displayName}}</text>
            <text class="card-meta">{{item.source || '未知来源'}} · {{item.talent.mainTalent || '待评估'}}</text>
          </view>
        </view>
        <button class="action-btn" bindtap="onArrangeInterview" data-id="{{item.recordId}}">安排面试</button>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">通知模板</text>
      <text class="section-subtitle">复制短信 / 微信内容</text>
    </view>
    <view wx:if="{{noticeCandidates.length === 0}}" class="empty-card">
      <text class="empty-text">当前还没有已排期的面试通知。</text>
    </view>
    <view wx:else class="card-list">
      <view wx:for="{{noticeCandidates}}" wx:key="recordId" class="card">
        <view class="candidate-row">
          <image wx:if="{{item.avatar}}" class="candidate-avatar" src="{{item.avatar}}" mode="aspectFill"></image>
          <view wx:else class="candidate-avatar avatar-placeholder">{{item.displayInitial}}</view>
          <view class="candidate-content">
            <text class="card-title">{{item.displayName}}</text>
            <text class="card-meta">{{item.scheduleText}}</text>
          </view>
        </view>
        <button class="action-btn secondary" bindtap="onGenerateNotice" data-id="{{item.recordId}}">生成通知</button>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">面试评分入口</text>
      <text class="section-subtitle">调用 S/A/B/C 评分系统</text>
    </view>
    <view wx:if="{{scoreCandidates.length === 0}}" class="empty-card">
      <text class="empty-text">当前没有待进入评分系统的候选人。</text>
    </view>
    <view wx:else class="card-list">
      <view wx:for="{{scoreCandidates}}" wx:key="recordId" class="card">
        <view class="candidate-row">
          <image wx:if="{{item.avatar}}" class="candidate-avatar" src="{{item.avatar}}" mode="aspectFill"></image>
          <view wx:else class="candidate-avatar avatar-placeholder">{{item.displayInitial}}</view>
          <view class="candidate-content">
            <text class="card-title">{{item.displayName}}</text>
            <text class="card-meta">当前状态：{{item.status}} · AI {{item.aiScore.overallScore}}</text>
          </view>
        </view>
        <button class="action-btn" bindtap="onOpenScore" data-id="{{item.recordId}}">进入评分</button>
      </view>
    </view>
  </view>
</view>
