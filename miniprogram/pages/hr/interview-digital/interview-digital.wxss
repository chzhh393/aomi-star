.page {
  min-height: 100vh;
  padding: 28rpx;
  background: #f6f2eb;
}

.hero,
.card,
.empty-card {
  padding: 28rpx;
  border-radius: 24rpx;
  background: #fffdf8;
  box-shadow: 0 12rpx 30rpx rgba(50, 44, 36, 0.08);
}

.hero-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #1f2831;
}

.hero-desc,
.card-meta,
.empty-text,
.section-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #72685f;
}

.section {
  margin-top: 24rpx;
}

.section-header {
  margin-bottom: 16rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2831;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.candidate-row {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.candidate-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  flex-shrink: 0;
  background: #d8d2ca;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #202f3d;
  color: #fff8ef;
  font-size: 32rpx;
  font-weight: 700;
}

.candidate-content {
  min-width: 0;
  flex: 1;
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2831;
}

.action-btn {
  margin-top: 18rpx;
  min-height: 76rpx;
  border-radius: 999rpx;
  background: #202f3d;
  color: #fff8ef;
  font-size: 24rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
}

.action-btn.secondary {
  background: #f3e3cf;
  color: #855029;
}

.action-btn::after {
  border: none;
}
